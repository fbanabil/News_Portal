@model ForgotPasswordResetDTO

@{
    var lang = Context.Request.Cookies["Language"];
    if (lang == null) lang = Languages.Bangla.ToString();
    bool isBangla = (lang == Languages.Bangla.ToString()) ? true : false;
}
@{
    ViewBag.Title = isBangla ? "পাসওয়ার্ড রিসেট" : "Reset Password";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


@await Html.PartialAsync("PartialViews/MessagePartial")


<div class="container d-flex align-items-center justify-content-center" style="min-height: 70vh;">
    <div class="col-12 col-sm-10 col-md-8 col-lg-5">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4 p-lg-5">
                <h1 class="h4 mb-1 text-center">@(isBangla ? "আপনার পাসওয়ার্ড রিসেট করুন" : "Reset Your Password")</h1>
                <p class="text-muted text-center mb-4">@(isBangla ? "নিচে আপনার নতুন পাসওয়ার্ড লিখুন" : "Enter your new password below")</p>

                <form asp-area="Identity" asp-controller="Account" asp-action="ConfirmResetPassword" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="Email" type="hidden" />
                    <input asp-for="Token" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label">@(isBangla ? "নতুন পাসওয়ার্ড" : "New Password")</label>
                        <div class="input-group">
                            <input asp-for="NewPassword"
                                   type="password"
                                   class="form-control"
                                   placeholder="@(isBangla ? "নতুন পাসওয়ার্ড লিখুন" : "Enter your new password")" />
                            <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('NewPassword')">
                                <i id="NewPasswordToggle" class="bi bi-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="NewPassword" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ConfirmNewPassword" class="form-label">@(isBangla ? "নতুন পাসওয়ার্ড নিশ্চিত করুন" : "Confirm New Password")</label>
                        <div class="input-group">
                            <input asp-for="ConfirmNewPassword"
                                   type="password"
                                   class="form-control"
                                   placeholder="@(isBangla ? "নতুন পাসওয়ার্ড আবার লিখুন" : "Confirm your new password")" />
                            <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('ConfirmNewPassword')">
                                <i id="ConfirmNewPasswordToggle" class="bi bi-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmNewPassword" class="text-danger"></span>
                    </div>

                    <div id="matchIndicator" style="display: none;" class="mb-3">
                        <small id="matchText" class="form-text"></small>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">@(isBangla ? "পাসওয়ার্ড রিসেট করুন" : "Reset Password")</button>
                    </div>
                </form>

                <div class="d-flex justify-content-between mt-3">
                    <a asp-area="Identity" asp-controller="Account" asp-action="AuthLogin" class="small text-decoration-none">
                        @(isBangla ? "লগইনে ফিরে যান" : "Back to Login")
                    </a>
                    <a asp-area="" asp-controller="Home" asp-action="Index" class="small text-decoration-none">
                        @(isBangla ? "হোমে ফিরে যান" : "Back to Home")
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<script>
    const isBangla = @Json.Serialize(isBangla);

    function togglePassword(inputId) {
        const input = document.getElementById(inputId);
        const toggle = document.getElementById(inputId + 'Toggle');

        if (input.type === 'password') {
            input.type = 'text';
            toggle.className = 'bi bi-eye-slash';
        } else {
            input.type = 'password';
            toggle.className = 'bi bi-eye';
        }
    }

    function checkPasswordMatch() {
        const password = document.getElementById('NewPassword').value;
        const confirmPassword = document.getElementById('ConfirmNewPassword').value;
        const matchIndicator = document.getElementById('matchIndicator');
        const matchText = document.getElementById('matchText');

        if (confirmPassword.length > 0) {
            matchIndicator.style.display = 'block';

            if (password === confirmPassword) {
                matchText.innerHTML = isBangla
                    ? '<i class="bi bi-check-circle me-1"></i>পাসওয়ার্ড মিলেছে'
                    : '<i class="bi bi-check-circle me-1"></i>Passwords match';
                matchText.className = 'text-success';
            } else {
                matchText.innerHTML = isBangla
                    ? '<i class="bi bi-x-circle me-1"></i>পাসওয়ার্ড মিলছে না'
                    : '<i class="bi bi-x-circle me-1"></i>Passwords do not match';
                matchText.className = 'text-danger';
            }
        } else {
            matchIndicator.style.display = 'none';
        }
    }

    document.addEventListener('DOMContentLoaded', function () {
        document.getElementById('NewPassword').addEventListener('input', checkPasswordMatch);
        document.getElementById('ConfirmNewPassword').addEventListener('input', checkPasswordMatch);
    });
</script>
