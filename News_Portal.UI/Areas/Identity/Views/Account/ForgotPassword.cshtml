@model ForgotPasswordDTO

@{
    var lang = Context.Request.Cookies["Language"];
    if (lang == null) lang = Languages.Bangla.ToString();
    bool isBangla = (lang == Languages.Bangla.ToString()) ? true : false;
}
@{
    ViewBag.Title = isBangla ? "পাসওয়ার্ড ভুলে গেছেন" : "Forgot Password";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@await Html.PartialAsync("PartialViews/MessagePartial")


<div class="container d-flex align-items-center justify-content-center" style="min-height: 70vh;">
    <div class="col-12 col-sm-10 col-md-8 col-lg-5">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4 p-lg-5">
                <h1 class="h4 mb-1 text-center">@(isBangla ? "পাসওয়ার্ড রিসেট" : "Reset Password")</h1>
                <p class="text-muted text-center mb-4">
                    @(isBangla ? "পাসওয়ার্ড রিসেট লিংক পেতে আপনার ইমেইল ঠিকানা লিখুন" : "Enter your email address to receive a password reset link")
                </p>

                <form asp-area="Identity" asp-controller="Account" asp-action="ForgotPasswordReset" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">@(isBangla ? "ইমেইল" : "Email")</label>
                        <input asp-for="Email"
                               class="form-control"
                               autocomplete="email"
                               placeholder="@(isBangla ? "আপনার ইমেইল লিখুন" : "you@example.com")" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">@(isBangla ? "রিসেট লিংক পাঠান" : "Send Reset Link")</button>
                    </div>
                </form>

                <div class="d-flex justify-content-between mt-3">
                    <a asp-area="Identity" asp-controller="Account" asp-action="AuthLogin" class="small text-decoration-none">
                        @(isBangla ? "লগইনে ফিরে যান" : "Back to Login")
                    </a>
                    <a asp-area="" asp-controller="Home" asp-action="Index" class="small text-decoration-none">
                        @(isBangla ? "হোমে ফিরে যান" : "Back to Home")
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}
