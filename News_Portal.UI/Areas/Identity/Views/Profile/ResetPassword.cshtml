@using News_Portal.Core.DTO.Profile
@model ResetPasswordDTO

@{
    var lang = Context.Request.Cookies["Language"];
    if (lang == null) lang = Languages.Bangla.ToString();
    bool isBangla = (lang == Languages.Bangla.ToString()) ? true : false;
}
@{
    ViewData["Title"] = isBangla ? "পাসওয়ার্ড পুনরায় সেট" : "Reset Password";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@await Html.PartialAsync("PartialViews/MessagePartial")

<div class="container py-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="h3 mb-1">
                        <i class="bi bi-key me-2 text-primary"></i>@(isBangla ? "পাসওয়ার্ড পুনরায় সেট" : "Reset Password")
                    </h1>
                    <p class="text-muted mb-0">@(isBangla ? "নতুন পাসওয়ার্ড তৈরি করুন" : "Create a new password for your account")</p>
                </div>
                <div>
                    <a href="@Url.Action("AuthLogin", "Account", new { area = "Identity" })"
                       class="btn btn-outline-primary">
                        <i class="bi bi-arrow-left me-1"></i>@(isBangla ? "লগ-ইন এ ফিরে যাই" : "Back to Login")
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 py-4">
                    <div class="d-flex align-items-center">
                        <div class="bg-primary-subtle rounded-circle p-3 me-3">
                            <i class="bi bi-shield-lock-fill text-primary fs-4"></i>
                        </div>
                        <div>
                            <h5 class="mb-1">@(isBangla ? "নতুন পাসওয়ার্ড সেট করুন" : "Set New Password")</h5>
                            <small class="text-muted">@(isBangla ? "নিচে আপনার নতুন পাসওয়ার্ড লিখুন" : "Enter your new password below")</small>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4">
                    <form asp-area="Identity" asp-controller="Profile" asp-action="ConfirmResetPasseord" method="post" id="resetPasswordForm">
                        @Html.AntiForgeryToken()

                        <input type="hidden" name="userId" value="@ViewBag.UserId" />
                        <input type="hidden" name="token" value="@ViewBag.Token" />

                        <div class="mb-4">
                            <label asp-for="Password" class="form-label fw-semibold">
                                <i class="bi bi-lock-fill me-1"></i>@(isBangla ? "নতুন পাসওয়ার্ড" : "New Password")
                            </label>
                            <div class="input-group-password">
                                <input asp-for="Password"
                                       type="password"
                                       class="form-control form-control-lg"
                                       placeholder="@(isBangla ? "নতুন পাসওয়ার্ড লিখুন" : "Enter your new password")"
                                       id="password"
                                       onkeyup="checkPasswordMatch()" />
                                <span class="password-toggle" onclick="togglePassword('password')">
                                    <i class="bi bi-eye" id="passwordToggle"></i>
                                </span>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ConfirmPassword" class="form-label fw-semibold">
                                <i class="bi bi-check-circle me-1"></i>@(isBangla ? "নতুন পাসওয়ার্ড নিশ্চিত করুন" : "Confirm New Password")
                            </label>
                            <div class="input-group-password">
                                <input asp-for="ConfirmPassword"
                                       type="password"
                                       class="form-control form-control-lg"
                                       placeholder="@(isBangla ? "নতুন পাসওয়ার্ড আবার লিখুন" : "Confirm your new password")"
                                       id="confirmPassword"
                                       onkeyup="checkPasswordMatch()" />
                                <span class="password-toggle" onclick="togglePassword('confirmPassword')">
                                    <i class="bi bi-eye" id="confirmPasswordToggle"></i>
                                </span>
                            </div>

                            <div id="matchIndicator" class="mt-2" style="display: none;">
                                <small id="matchText" class="text-danger">
                                    <i class="bi bi-x-circle me-1"></i>@(isBangla ? "পাসওয়ার্ড মিলছে না" : "Passwords do not match")
                                </small>
                            </div>

                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a href="@Url.Action("AuthLogin", "Account", new { area = "Identity" })"
                               class="btn btn-outline-secondary btn-lg me-md-2">
                                <i class="bi bi-x-lg me-1"></i>@(isBangla ? "বাতিল" : "Cancel")
                            </a>
                            <button type="submit" class="btn btn-primary btn-lg" id="submitBtn">
                                <i class="bi bi-check-lg me-1"></i>@(isBangla ? "পাসওয়ার্ড রিসেট করুন" : "Reset Password")
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4 col-xl-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-info-subtle border-0 py-3">
                    <h6 class="mb-0 text-info">
                        <i class="bi bi-info-circle me-2"></i>@(isBangla ? "পাসওয়ার্ড রিসেট তথ্য" : "Password Reset Info")
                    </h6>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <h6 class="text-info">
                            <i class="bi bi-shield-check me-1"></i>@(isBangla ? "এরপর কী হবে?" : "What happens next?")
                        </h6>
                        <p class="text-muted small mb-3">
                            @(isBangla
                                                        ? "পাসওয়ার্ড সফলভাবে রিসেট হলে আপনাকে লগইন পেজে পাঠানো হবে, সেখানে নতুন পাসওয়ার্ড দিয়ে সাইন ইন করতে পারবেন।"
                                                        : "After successfully resetting your password, you'll be redirected to the login page where you can sign in with your new password.")
                        </p>
                    </div>

                    <div class="mb-3">
                        <h6 class="text-info">
                            <i class="bi bi-clock me-1"></i>@(isBangla ? "রিসেট লিংক মেয়াদ" : "Reset Link Expiration")
                        </h6>
                        <p class="text-muted small mb-3">
                            @(isBangla
                                                        ? "এই পাসওয়ার্ড রিসেট লিংক সীমিত সময়ের জন্য বৈধ। মেয়াদ শেষ হলে নতুন করে অনুরোধ করতে হবে।"
                                                        : "This password reset link is valid for a limited time. If it expires, you'll need to request a new one.")
                        </p>
                    </div>

                    <div>
                        <h6 class="text-info">
                            <i class="bi bi-person-check me-1"></i>@(isBangla ? "অ্যাকাউন্ট নিরাপত্তা" : "Account Security")
                        </h6>
                        <p class="text-muted small mb-0">
                            @(isBangla
                                                        ? "আপনার অ্যাকাউন্ট নিরাপদ রাখতে একটি শক্তিশালী পাসওয়ার্ড নির্বাচন করুন। এটি ইউনিক রাখুন এবং অন্য কারও সাথে শেয়ার করবেন না।"
                                                        : "Choose a strong password to keep your account secure. Make it unique and don't share it with others.")
                        </p>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm mt-4">
                <div class="card-header bg-success-subtle border-0 py-3">
                    <h6 class="mb-0 text-success">
                        <i class="bi bi-lightbulb me-2"></i>@(isBangla ? "পাসওয়ার্ড টিপস" : "Password Tips")
                    </h6>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2">
                            <div class="d-flex">
                                <i class="bi bi-check-circle-fill text-success me-2 mt-1 flex-shrink-0"></i>
                                <small>@(isBangla ? "অক্ষর, সংখ্যা ও সিম্বল মিলিয়ে ব্যবহার করুন" : "Use a mix of letters, numbers, and symbols")</small>
                            </div>
                        </li>
                        <li class="mb-2">
                            <div class="d-flex">
                                <i class="bi bi-check-circle-fill text-success me-2 mt-1 flex-shrink-0"></i>
                                <small>@(isBangla ? "কমপক্ষে ৮ অক্ষরের পাসওয়ার্ড দিন" : "Make it at least 8 characters long")</small>
                            </div>
                        </li>
                        <li class="mb-2">
                            <div class="d-flex">
                                <i class="bi bi-check-circle-fill text-success me-2 mt-1 flex-shrink-0"></i>
                                <small>@(isBangla ? "ব্যক্তিগত তথ্য ব্যবহার এড়িয়ে চলুন" : "Avoid personal information")</small>
                            </div>
                        </li>
                        <li>
                            <div class="d-flex">
                                <i class="bi bi-check-circle-fill text-success me-2 mt-1 flex-shrink-0"></i>
                                <small>@(isBangla ? "পুরোনো পাসওয়ার্ড পুনরায় ব্যবহার করবেন না" : "Don't reuse old passwords")</small>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Razor variable into JS safely
        const isBangla = @Json.Serialize(isBangla);

        document.addEventListener('DOMContentLoaded', function () {
            console.log('ResetPassword page loaded successfully');
            initializeFormValidation();
        });

        function togglePassword(inputId) {
            const input = document.getElementById(inputId);
            const toggle = document.getElementById(inputId + 'Toggle');

            if (input.type === 'password') {
                input.type = 'text';
                toggle.className = 'bi bi-eye-slash';
            } else {
                input.type = 'password';
                toggle.className = 'bi bi-eye';
            }
        }

        function checkPasswordMatch() {
            const password = document.getElementById('password').value;
            const confirmPassword = document.getElementById('confirmPassword').value;
            const matchIndicator = document.getElementById('matchIndicator');
            const matchText = document.getElementById('matchText');

            if (confirmPassword.length > 0) {
                matchIndicator.style.display = 'block';

                if (password === confirmPassword) {
                    matchText.innerHTML = isBangla
                        ? '<i class="bi bi-check-circle me-1"></i>পাসওয়ার্ড মিলেছে'
                        : '<i class="bi bi-check-circle me-1"></i>Passwords match';
                    matchText.className = 'text-success';
                } else {
                    matchText.innerHTML = isBangla
                        ? '<i class="bi bi-x-circle me-1"></i>পাসওয়ার্ড মিলছে না'
                        : '<i class="bi bi-x-circle me-1"></i>Passwords do not match';
                    matchText.className = 'text-danger';
                }
            } else {
                matchIndicator.style.display = 'none';
            }
        }

        function initializeFormValidation() {
            const form = document.getElementById('resetPasswordForm');
            const submitBtn = document.getElementById('submitBtn');

            form.addEventListener('submit', function (e) {
                const originalText = submitBtn.innerHTML;
                submitBtn.innerHTML = isBangla
                    ? '<i class="bi bi-hourglass-split me-1"></i>রিসেট হচ্ছে...'
                    : '<i class="bi bi-hourglass-split me-1"></i>Resetting...';
                submitBtn.disabled = true;

                const password = document.getElementById('password').value;
                const confirmPassword = document.getElementById('confirmPassword').value;

                let isValid = true;
                let errorMessage = '';

                if (!password.trim()) {
                    isValid = false;
                    errorMessage = isBangla ? 'নতুন পাসওয়ার্ড প্রয়োজন।' : 'New password is required.';
                } else if (!confirmPassword.trim()) {
                    isValid = false;
                    errorMessage = isBangla ? 'পাসওয়ার্ড নিশ্চিতকরণ প্রয়োজন।' : 'Password confirmation is required.';
                } else if (password !== confirmPassword) {
                    isValid = false;
                    errorMessage = isBangla ? 'পাসওয়ার্ড এবং নিশ্চিতকরণ মিলছে না।' : 'Password and confirmation do not match.';
                }

                if (!isValid) {
                    e.preventDefault();
                    showAlert('danger', errorMessage);
                    submitBtn.innerHTML = originalText;
                    submitBtn.disabled = false;
                }
            });
        }

        function showAlert(type, message) {
            const icon = (type === 'success') ? 'check-circle' : 'exclamation-triangle';

            const alertHtml = `
                <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                    <i class="bi bi-${icon} me-2"></i>
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>`;

            const container = document.querySelector('.container');
            container.insertAdjacentHTML('afterbegin', alertHtml);

            setTimeout(() => {
                const alert = container.querySelector('.alert');
                if (alert) {
                    bootstrap.Alert.getInstance(alert)?.close();
                }
            }, 5000);

            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
