@using News_Portal.Core.DTO.Profile
@model PasswordChangeDTO
@{
    var lang = Context.Request.Cookies["Language"];
    bool isBangla = (lang == Languages.Bangla.ToString()) ? true : false;
}
@{
    ViewData["Title"] = isBangla ? "পাসওয়ার্ড পরিবর্তন" : "Change Password";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container py-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="h3 mb-1">
                        <i class="bi bi-shield-lock me-2 text-primary"></i>@(isBangla ? "পাসওয়ার্ড পরিবর্তন" : "Change Password")
                    </h1>
                    <p class="text-muted mb-0">@(isBangla ? "আরও নিরাপত্তার জন্য আপনার অ্যাকাউন্ট পাসওয়ার্ড আপডেট করুন" : "Update your account password for enhanced security")</p>
                </div>
                <div>
                    <a href="@Url.Action("ProfileDetails", "Profile", new { area = "Identity" })"
                       class="btn btn-outline-secondary me-2">
                        <i class="bi bi-arrow-left me-1"></i>@(isBangla ? "প্রোফাইলে ফিরে যান" : "Back to Profile")
                    </a>
                    <a href="@Url.Action("Index", "Home", new { area = "" })"
                       class="btn btn-outline-primary">
                        <i class="bi bi-house me-1"></i>@(isBangla ? "হোম" : "Home")
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-7">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 py-4">
                    <div class="d-flex align-items-center">
                        <div class="bg-primary-subtle rounded-circle p-3 me-3">
                            <i class="bi bi-key-fill text-primary fs-4"></i>
                        </div>
                        <div>
                            <h5 class="mb-1">@(isBangla ? "পাসওয়ার্ড আপডেট" : "Password Update")</h5>
                            <small class="text-muted">@(isBangla ? "বর্তমান পাসওয়ার্ড লিখুন এবং একটি নতুন নিরাপদ পাসওয়ার্ড নির্বাচন করুন" : "Enter your current password and choose a new secure password")</small>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4">
                    <form asp-area="Identity" asp-controller="Profile" asp-action="ChangePassword" method="post" id="changePasswordForm">
                        @Html.AntiForgeryToken()

                        <div class="mb-4">
                            <label asp-for="CurrentPassword" class="form-label fw-semibold">
                                <i class="bi bi-lock me-1"></i>@(isBangla ? "বর্তমান পাসওয়ার্ড" : "Current Password")
                            </label>
                            <div class="input-group-password">
                                <input asp-for="CurrentPassword"
                                       type="password"
                                       class="form-control form-control-lg"
                                       placeholder="@(isBangla ? "বর্তমান পাসওয়ার্ড লিখুন" : "Enter your current password")"
                                       id="currentPassword" />
                                <span class="password-toggle" onclick="togglePassword('currentPassword')">
                                    <i class="bi bi-eye" id="currentPasswordToggle"></i>
                                </span>
                            </div>
                            <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="NewPassword" class="form-label fw-semibold">
                                <i class="bi bi-shield-check me-1"></i>@(isBangla ? "নতুন পাসওয়ার্ড" : "New Password")
                            </label>
                            <div class="input-group-password">
                                <input asp-for="NewPassword"
                                       type="password"
                                       class="form-control form-control-lg"
                                       placeholder="@(isBangla ? "নতুন পাসওয়ার্ড লিখুন" : "Enter your new password")"
                                       id="newPassword"
                                       onkeyup="checkPasswordMatch()" />
                                <span class="password-toggle" onclick="togglePassword('newPassword')">
                                    <i class="bi bi-eye" id="newPasswordToggle"></i>
                                </span>
                            </div>
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ConfirmNewPassword" class="form-label fw-semibold">
                                <i class="bi bi-check-circle me-1"></i>@(isBangla ? "নতুন পাসওয়ার্ড নিশ্চিত করুন" : "Confirm New Password")
                            </label>
                            <div class="input-group-password">
                                <input asp-for="ConfirmNewPassword"
                                       type="password"
                                       class="form-control form-control-lg"
                                       placeholder="@(isBangla ? "নতুন পাসওয়ার্ড আবার লিখুন" : "Confirm your new password")"
                                       id="confirmNewPassword"
                                       onkeyup="checkPasswordMatch()" />
                                <span class="password-toggle" onclick="togglePassword('confirmNewPassword')">
                                    <i class="bi bi-eye" id="confirmNewPasswordToggle"></i>
                                </span>
                            </div>

                            <div id="matchIndicator" class="mt-2" style="display: none;">
                                <small id="matchText" class="text-danger">
                                    <i class="bi bi-x-circle me-1"></i>@(isBangla ? "পাসওয়ার্ড মিলছে না" : "Passwords do not match")
                                </small>
                            </div>

                            <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a href="@Url.Action("ProfileDetails", "Profile", new { area = "Identity" })"
                               class="btn btn-outline-secondary btn-lg me-md-2">
                                <i class="bi bi-x-lg me-1"></i>@(isBangla ? "বাতিল" : "Cancel")
                            </a>
                            <button type="submit" class="btn btn-primary btn-lg" id="submitBtn">
                                <i class="bi bi-check-lg me-1"></i>@(isBangla ? "পাসওয়ার্ড আপডেট করুন" : "Update Password")
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4 col-xl-3">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-success-subtle border-0 py-3">
                    <h6 class="mb-0 text-success">
                        <i class="bi bi-shield-check me-2"></i>@(isBangla ? "নিরাপত্তা টিপস" : "Security Tips")
                    </h6>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-3">
                            <div class="d-flex">
                                <i class="bi bi-check-circle-fill text-success me-2 mt-1 flex-shrink-0"></i>
                                <small>@(isBangla ? "অন্যান্য অ্যাকাউন্টে ব্যবহার করেন না এমন একটি ইউনিক পাসওয়ার্ড ব্যবহার করুন" : "Use a unique password that you don't use for other accounts")</small>
                            </div>
                        </li>
                        <li class="mb-3">
                            <div class="d-flex">
                                <i class="bi bi-check-circle-fill text-success me-2 mt-1 flex-shrink-0"></i>
                                <small>@(isBangla ? "আপনার মনে রাখা সহজ এমন পাসওয়ার্ড নির্বাচন করুন" : "Choose a password that's easy for you to remember")</small>
                            </div>
                        </li>
                        <li class="mb-3">
                            <div class="d-flex">
                                <i class="bi bi-check-circle-fill text-success me-2 mt-1 flex-shrink-0"></i>
                                <small>@(isBangla ? "অন্যরা জানতে পারে এমন ব্যক্তিগত তথ্য ব্যবহার এড়িয়ে চলুন" : "Avoid using personal information that others might know")</small>
                            </div>
                        </li>
                        <li class="mb-3">
                            <div class="d-flex">
                                <i class="bi bi-check-circle-fill text-success me-2 mt-1 flex-shrink-0"></i>
                                <small>@(isBangla ? "আরও নিরাপত্তার জন্য পাসওয়ার্ড ম্যানেজার ব্যবহার করতে পারেন" : "Consider using a password manager for better security")</small>
                            </div>
                        </li>
                        <li>
                            <div class="d-flex">
                                <i class="bi bi-check-circle-fill text-success me-2 mt-1 flex-shrink-0"></i>
                                <small>@(isBangla ? "পাসওয়ার্ড কমপ্রোমাইজ হয়েছে মনে হলে দ্রুত আপডেট করুন" : "Update your password if you suspect it's been compromised")</small>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>

            <div class="card border-0 shadow-sm mt-4">
                <div class="card-body">
                    <div class="text-center">
                        <i class="bi bi-info-circle display-6 text-info mb-2"></i>
                        <h6 class="text-info">@(isBangla ? "পাসওয়ার্ড স্বাধীনতা" : "Password Freedom")</h6>
                        <small class="text-muted">
                            @(isBangla ? "আপনি আপনার পছন্দের যেকোনো পাসওয়ার্ড দিতে পারেন। নিশ্চিত করুন যেন এটি আপনার মনে থাকে!" : "You can choose any password you prefer. Make sure it's something you'll remember!")
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const isBangla = @Json.Serialize(isBangla);

        document.addEventListener('DOMContentLoaded', function() {
            console.log('ChangePassword page loaded successfully');
            initializeFormValidation();
        });

        function togglePassword(inputId) {
            const input = document.getElementById(inputId);
            const toggle = document.getElementById(inputId + 'Toggle');

            if (input.type === 'password') {
                input.type = 'text';
                toggle.className = 'bi bi-eye-slash';
            } else {
                input.type = 'password';
                toggle.className = 'bi bi-eye';
            }
        }

        function checkPasswordMatch() {
            const newPassword = document.getElementById('newPassword').value;
            const confirmPassword = document.getElementById('confirmNewPassword').value;
            const matchIndicator = document.getElementById('matchIndicator');
            const matchText = document.getElementById('matchText');

            if (confirmPassword.length > 0) {
                matchIndicator.style.display = 'block';

                if (newPassword === confirmPassword) {
                    matchText.innerHTML = isBangla
                        ? '<i class="bi bi-check-circle me-1"></i>পাসওয়ার্ড মিলেছে'
                        : '<i class="bi bi-check-circle me-1"></i>Passwords match';
                    matchText.className = 'text-success';
                } else {
                    matchText.innerHTML = isBangla
                        ? '<i class="bi bi-x-circle me-1"></i>পাসওয়ার্ড মিলছে না'
                        : '<i class="bi bi-x-circle me-1"></i>Passwords do not match';
                    matchText.className = 'text-danger';
                }
            } else {
                matchIndicator.style.display = 'none';
            }
        }

        function initializeFormValidation() {
            const form = document.getElementById('changePasswordForm');
            const submitBtn = document.getElementById('submitBtn');

            form.addEventListener('submit', function(e) {
                const originalText = submitBtn.innerHTML;
                submitBtn.innerHTML = isBangla
                    ? '<i class="bi bi-hourglass-split me-1"></i>আপডেট হচ্ছে...'
                    : '<i class="bi bi-hourglass-split me-1"></i>Updating...';
                submitBtn.disabled = true;

                const currentPassword = document.getElementById('currentPassword').value;
                const newPassword = document.getElementById('newPassword').value;
                const confirmPassword = document.getElementById('confirmNewPassword').value;

                let isValid = true;
                let errorMessage = '';

                if (!currentPassword.trim()) {
                    isValid = false;
                    errorMessage = isBangla ? 'বর্তমান পাসওয়ার্ড প্রয়োজন।' : 'Current password is required.';
                } else if (!newPassword.trim()) {
                    isValid = false;
                    errorMessage = isBangla ? 'নতুন পাসওয়ার্ড প্রয়োজন।' : 'New password is required.';
                } else if (newPassword !== confirmPassword) {
                    isValid = false;
                    errorMessage = isBangla ? 'নতুন পাসওয়ার্ড এবং নিশ্চিতকরণ মিলছে না।' : 'New password and confirmation do not match.';
                } else if (newPassword.length < 8) {
                    isValid = false;
                    errorMessage = isBangla ? 'নতুন পাসওয়ার্ড কমপক্ষে ৮ অক্ষরের হতে হবে।' : 'New password must be at least 8 characters long.';
                } else if (currentPassword === newPassword) {
                    isValid = false;
                    errorMessage = isBangla ? 'নতুন পাসওয়ার্ড বর্তমান পাসওয়ার্ড থেকে আলাদা হতে হবে।' : 'New password must be different from current password.';
                }

                if (!isValid) {
                    e.preventDefault();
                    showAlert('danger', errorMessage);
                    submitBtn.innerHTML = originalText;
                    submitBtn.disabled = false;
                }
            });
        }

        function showAlert(type, message) {
            const alertHtml = `
                <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                    <i class="bi bi-${type === 'success' ? 'check-circle' : 'exclamation-triangle'} me-2"></i>
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>`;

            const container = document.querySelector('.container');
            container.insertAdjacentHTML('afterbegin', alertHtml);

            setTimeout(() => {
                const alert = container.querySelector('.alert');
                if (alert) {
                    bootstrap.Alert.getInstance(alert)?.close();
                }
            }, 5000);

            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
