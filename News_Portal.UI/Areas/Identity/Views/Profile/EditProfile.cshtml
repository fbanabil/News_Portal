@model ProfileToUpdateDTO
@{
    ViewData["Title"] = "Edit Profile";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}


<div class="container py-4">
    <div class="profile-form-container">
        <div class="text-center mb-4">
            <h1 class="h3 mb-2">Edit Profile</h1>
            <p class="text-muted">Update your personal information and preferences</p>
        </div>

        <div class="card">
            <div class="card-header py-3">
                <h5 class="mb-0">
                    <i class="bi bi-person-gear me-2"></i>
                    Personal Information
                </h5>
            </div>
            <div class="card-body p-4">
                <form asp-area="Identity" asp-controller="Profile" asp-action="UpdateProfile" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    
                    <div asp-validation-summary="All" class="validation-summary-errors" role="alert" style="display: none;">
                        <strong>Please correct the following errors:</strong>
                    </div>

                    <div class="row mb-4">
                        <div class="col-12">
                            <div class="text-center mb-3">
                                <label class="form-label fw-semibold mb-3">
                                    <i class="bi bi-image me-1"></i>Profile Picture *
                                </label>
                                <div class="position-relative d-inline-block">
                                    <img src="@(Model.ExistingProfileImageUrl ?? ViewBag.DefaultImageUrl)"
                                         alt="Profile Picture"
                                         class="rounded-circle profile-image-preview"
                                         id="profileImagePreview"
                                         onerror="this.src=@ViewBag.DefaultImageUrl" />
                                    <div class="position-absolute bottom-0 end-0">
                                        <label for="profileImageFile" class="btn btn-primary btn-sm rounded-circle" style="cursor: pointer;" title="Change Profile Picture">
                                            <i class="bi bi-camera-fill"></i>
                                        </label>
                                    </div>
                                </div>
                                
                                <input asp-for="ProfileImage" 
                                       type="file" 
                                       id="profileImageFile" 
                                       class="d-none" 
                                       accept="image/*" 
                                       onchange="previewImage(this)" />
                                
                                <input asp-for="ExistingProfileImageUrl" type="hidden" />
                                
                                <span asp-validation-for="ProfileImage" class="text-danger"></span>
                                <span asp-validation-for="ExistingProfileImageUrl" class="text-danger"></span>
                                
                                <div id="imageStatus" class="image-upload-status status-current">
                                    <i class="bi bi-info-circle me-1"></i>
                                    <span id="imageStatusText">Using current profile picture</span>
                                </div>
                                
                                <div class="mt-2">
                                    <small class="text-muted">
                                        Click the camera icon to upload a new profile picture<br>
                                        Supported formats: JPG, PNG, GIF (Max: 5MB)
                                    </small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="PersonName" 
                                       class="form-control" 
                                       id="personName" 
                                       placeholder="Enter your full name"
                                       maxlength="100"
                                       required />
                                <label for="personName">
                                    <i class="bi bi-person me-1"></i>Full Name *
                                </label>
                            </div>
                            <span asp-validation-for="PersonName" class="field-validation-error"></span>
                        </div>

                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="PhoneNumber" 
                                       class="form-control" 
                                       id="phoneNumber" 
                                       placeholder="Enter your phone number"
                                       type="tel"
                                       required />
                                <label for="phoneNumber">
                                    <i class="bi bi-telephone me-1"></i>Phone Number *
                                </label>
                            </div>
                            <span asp-validation-for="PhoneNumber" class="field-validation-error"></span>
                        </div>
                    </div>

                    <div class="row mt-4">
                        <div class="col-12">
                            <hr class="my-4">
                            <h6 class="text-muted mb-3">
                                <i class="bi bi-info-circle me-2"></i>
                                Additional Information
                            </h6>
                            <div class="alert alert-info border-0" role="alert">
                                <i class="bi bi-lightbulb me-2"></i>
                                <strong>Note:</strong> Fields marked with <span class="text-danger">*</span> are required. 
                                Your email address cannot be changed from this page. 
                                If you need to update your email, please contact support.
                            </div>
                        </div>
                    </div>

                    <div class="row mt-4">
                        <div class="col-12">
                            <hr class="my-4">
                            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                                <a href="@Url.Action("ProfileDetails", "Profile", new { area = "Identity" })" 
                                   class="btn btn-outline-secondary">
                                    <i class="bi bi-arrow-left me-2"></i>Cancel
                                </a>
                                
                                <div class="d-flex gap-2 flex-wrap">
                                    <button type="reset" class="btn btn-outline-warning" onclick="resetForm()">
                                        <i class="bi bi-arrow-clockwise me-2"></i>Reset Changes
                                    </button>
                                    <button type="submit" class="btn btn-primary" id="submitBtn">
                                        <i class="bi bi-check-circle me-2"></i>Update Profile
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="card mt-4">
            <div class="card-body">
                <h6 class="card-title">
                    <i class="bi bi-shield-check text-success me-2"></i>
                    Validation Guidelines
                </h6>
                <div class="row">
                    <div class="col-md-6">
                        <ul class="mb-0 small text-muted">
                            <li><strong>Full Name:</strong> Required, maximum 100 characters</li>
                            <li><strong>Phone Number:</strong> Required, must be valid phone format</li>
                        </ul>
                    </div>
                    <div class="col-md-6">
                        <ul class="mb-0 small text-muted">
                            <li><strong>Profile Picture:</strong> Current image maintained if no new upload</li>
                            <li><strong>File Size:</strong> Maximum 5MB for new images</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    
    <script>
        $(document).ready(function() {
            if ($('.field-validation-error:contains("field is required"), .field-validation-error:not(:empty)').length > 0) {
                $('.validation-summary-errors').show();
            }
            
            $.validator.addMethod("phone", function(value, element) {
                return this.optional(element) || /^[\+]?[\s\-\(\)]*([0-9][\s\-\(\)]*){10,}$/i.test(value);
            }, "Please enter a valid phone number");

            $('#personName').on('blur input', function() {
                validateField($(this), function(value) {
                    if (!value || value.trim() === '') {
                        return 'Full Name is required';
                    }
                    if (value.length > 100) {
                        return 'Full Name cannot exceed 100 characters';
                    }
                    return null;
                });
            });

            $('#phoneNumber').on('blur input', function() {
                validateField($(this), function(value) {
                    if (!value || value.trim() === '') {
                        return 'Phone Number is required';
                    }
                    const phoneRegex = /^[\+]?[\s\-\(\)]*([0-9][\s\-\(\)]*){10,}$/i;
                    if (!phoneRegex.test(value)) {
                        return 'Please enter a valid phone number';
                    }
                    return null;
                });
            });

            $('#profileImageFile').on('change', function() {
                const file = this.files[0];
                if (file) {
                    if (file.size > 5 * 1024 * 1024) {
                        alert('File size must be less than 5MB');
                        $(this).val('');
                        resetImageStatus();
                        return;
                    }
                    
                    const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/gif'];
                    if (!allowedTypes.includes(file.type)) {
                        alert('Please select a valid image file (JPG, PNG, GIF)');
                        $(this).val('');
                        resetImageStatus();
                        return;
                    }
                    
                    updateImageStatus('new', `New image selected: ${file.name}`);
                } else {
                    resetImageStatus();
                }
            });

            $('form').on('submit', function(e) {
                const submitBtn = $('#submitBtn');
                const isValid = $(this).valid();
                
                if (isValid) {
                    submitBtn.prop('disabled', true).html('<i class="bi bi-hourglass-split me-2"></i>Updating...');
                }
                
                return isValid;
            });
        });

        function validateField($field, validationFunc) {
            const value = $field.val();
            const errorMessage = validationFunc(value);
            const $errorSpan = $field.closest('.col-md-6, .col-12').find('.field-validation-error');
            
            if (errorMessage) {
                $field.addClass('input-validation-error');
                $errorSpan.text(errorMessage).show();
            } else {
                $field.removeClass('input-validation-error');
                $errorSpan.text('').hide();
            }
        }

        function previewImage(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                
                reader.onload = function(e) {
                    $('#profileImagePreview').attr('src', e.target.result);
                };
                
                reader.readAsDataURL(input.files[0]);
            }
        }

        function updateImageStatus(type, message) {
            const $status = $('#imageStatus');
            const $statusText = $('#imageStatusText');
            
            $status.removeClass('status-current status-new');
            
            if (type === 'new') {
                $status.addClass('status-new');
                $statusText.html('<i class="bi bi-upload me-1"></i>' + message);
            } else {
                $status.addClass('status-current');
                $statusText.html('<i class="bi bi-info-circle me-1"></i>' + message);
            }
        }

        function resetImageStatus() {
            updateImageStatus('current', 'Using current profile picture');
        }

        function resetForm() {
            if (confirm('Are you sure you want to reset all changes?')) {
                $('form')[0].reset();
                
                $('.input-validation-error').removeClass('input-validation-error');
                $('.field-validation-error').text('').hide();
                $('.validation-summary-errors').hide();
                
                const originalImageUrl = '@(Model.ExistingProfileImageUrl ?? ViewBag.DefaultImageUrl)';
                $('#profileImagePreview').attr('src', originalImageUrl);
                
                $('#profileImageFile').val('');
                resetImageStatus();
            }
        }
    </script>
}

