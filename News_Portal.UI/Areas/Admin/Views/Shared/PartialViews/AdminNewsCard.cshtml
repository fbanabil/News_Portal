@model AuthorsNewsToShowDTO
@{
    var lang = Context.Request.Cookies["Language"];
    if (lang == null) lang = Languages.Bangla.ToString();
    bool isBangla = (lang == Languages.Bangla.ToString()) ? true : false;
}
<a asp-controller="AdminActions"
   asp-action="DetailedNews"
   asp-area="Admin"
   asp-route-newsId="@Model.NewsId"
   class="news-card-link text-decoration-none d-block"
   aria-label="@(isBangla ? $"বিস্তারিত: {Model.NewsTitle}" : $"Read '{Model.NewsTitle}'")">

    <article class="news-card-horizontal">

        <div class="news-media" aria-hidden="true">
            @if (Model.Images != null && Model.Images.Any())
            {
                <img src="@Model.Images.First().ImageUrl" alt="@Model.NewsTitle" loading="lazy" />
            }
            else
            {
                <div class="news-media-placeholder">@(isBangla ? "কোন ছবি নেই" : "No Image")</div>
            }
        </div>

        <div class="news-body">
            <header class="news-header">
                <h3 class="news-title">@Model.NewsTitle</h3>

                <div class="news-meta">
                    <span class="meta-pill">
                        @(isBangla ? Model.NewsType.GetDisplayName() : Model.NewsType.ToString())
                    </span>
                    <span class="meta-pill status">
                        @(isBangla ? Model.NewsStatus.GetDisplayName() : Model.NewsStatus.ToString())
                    </span>
                    <span class="meta-date">
                        @(isBangla ? Model.PublishedDate.GetBengaliDate() : Model.PublishedDate.ToString("MMM dd, yyyy"))
                    </span>
                </div>
            </header>

            <p class="news-excerpt">
                @(Model.NewsContent?.Length > 170
                                ? Model.NewsContent.Substring(0, 170) + "..."
                                : Model.NewsContent)
            </p>

            <div class="news-footer">
                <span class="read-more">
                    @(isBangla ? "বিস্তারিত দেখুন" : "Read details") <span aria-hidden="true">→</span>
                </span>
            </div>
        </div>

    </article>
</a>

