@model SideBarDTO
@using News_Portal.Core.Enums
@using System.Text.Json

@{
    bool isPinned= ViewBag.IsPinned ?? false;
}
@{
    var lang = Context.Request.Cookies["Language"];
    if (lang == null) lang = Languages.Bangla.ToString();
    bool isBangla = (lang == Languages.Bangla.ToString()) ? true : false;
}

@if (ViewBag.Title == "Admin Actions" || ViewBag.Title == "এডমিনের কাজ") 
{

    <div class="admin-sidebar">
        <div class="card mb-3 shadow-sm">
            <div class="card-header d-flex align-items-center justify-content-between">
                <strong class="mb-0">@(isBangla ? "এডমিন" : "Admins")</strong>
                <small class="text-muted">@(isBangla ? "ইমেইল দ্বারা পরিচালনা" : "Manage by email")</small>
            </div>

            <div class="card-body">
                <form id="addAdminForm" method="post" asp-area="Admin" asp-controller="AdminActions" asp-action="AddAuthor" class="mb-3" role="form" novalidate>
                    @Html.AntiForgeryToken()
                    <label class="form-label visually-hidden" for="AddAuthor_Email">@(isBangla ? "ইমেইল দিয়ে লেখক যোগ করুন" : "Add author by email")</label>
                    <div class="input-group">
                        <input asp-for="authorAddRemoveDTO.AddEmail" class="form-control" placeholder="author@example.com" aria-label="Author email" />
                        <button type="submit" class="btn btn-primary" title="@(isBangla ? "লেখক যুক্ত করুন" : "Add author")">
                            <i class="bi bi-person-plus"></i>
                        </button>
                    </div>
                    <span asp-validation-for="authorAddRemoveDTO.AddEmail" class="text-danger"></span>
                </form>

                <form id="removeAdminForm" method="post" asp-area="Admin" asp-controller="AdminActions" asp-action="RemoveAuthor" class="mb-2" role="form" novalidate>
                    @Html.AntiForgeryToken()
                    <label class="form-label visually-hidden" for="RemoveAuthor_Email">@(isBangla ? "ইমেইল দিয়ে লেখক সরান" : "Remove author by email")</label>
                    <div class="input-group">
                        <select asp-for="authorAddRemoveDTO.RemoveEmail" class="form-control" asp-items="@ViewBag.AuthorsList">
                            <option value="">-- @(isBangla ? "লেখক নির্বাচন করুন" : "Select Author") --</option>
                        </select>
                        <span asp-validation-for="authorAddRemoveDTO.RemoveEmail" class="text-danger"></span>
                        <button type="submit" class="btn btn-outline-danger" title="@(isBangla ? "লেখক সরান" : "Remove Author")">
                            <i class="bi bi-person-dash"></i>
                        </button>
                    </div>
                    @* <span asp-validation-for="RemoveEmail" class="text-danger" ></span> *@
                </form>

                <div class="mt-2 text-muted small">
                    @(isBangla ? "ইমেইল ঠিকানা ব্যবহার করে লেখক যোগ/বাতিল করুন। সম্পূর্ণ লেখক পৃষ্ঠায় ব্যাচ ম্যানেজমেন্ট উপলব্ধ।" : "Use email addresses to add or remove author users. Bulk management is available on the full author users page.")
                </div>
                <div class="mb-2">
                    <a asp-area="Admin" asp-controller="AdminActions" asp-action="GetUsers" class="list-group-item list-group-item-action d-flex justify-content-center align-items-center">
                        @(isBangla? "ব্যবহারকারী": "Users")
                    </a>
                </div>
                
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header d-flex align-items-center justify-content-between">
                <strong class="mb-0">@(isBangla ? "স্ট্যাটাস ফিল্টার" : "Status Filters")</strong>
                <small class="text-muted">@(isBangla ? "দৃশ্যমানতা" : "Visibility")</small>
            </div>

            <div class="card-body">
                @{

                    Func<NewsStatus, string> badgeClass = s => s switch
                    {
                        NewsStatus.Pending => "bg-secondary",
                        NewsStatus.Published => "bg-success",
                        NewsStatus.Rejected => "bg-danger",
                        NewsStatus.Hidden => "bg-dark",
                        NewsStatus.Blacklisted => "bg-warning text-dark",
                        _ => "bg-secondary"
                    };
                }

                <div class="list-group list-group-flush mb-3">
                    <a asp-area="Admin"
                       asp-controller="AdminActions"
                       asp-action="Index"
                       asp-route-newsstatus=""
                       class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        <span class="me-2">@(isBangla ? "সব" : "All")</span>
                    </a>
                    @foreach (NewsStatus status in Enum.GetValues(typeof(NewsStatus)))
                    {
                        <a asp-area="Admin"
                           asp-controller="AdminActions"
                           asp-action="Index"
                           asp-route-newsstatus="@status"
                           class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                            <span class="me-2">@(isBangla? status.GetDisplayName() : status)</span>
                            <span class="badge rounded-pill @badgeClass(status)">@(isBangla?status.GetDisplayName() : status)</span>
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>



}
else if(ViewBag.Title == "News Details" || ViewBag.Title == "সংবাদ বিস্তারিত")
{
    Model.adminsNewsDetailedDTO = ViewBag.adminsNewsDetailedDTO;

    string returnUrl = ViewBag.PreviousUrl;

    var dto = Model.adminsNewsDetailedDTO as News_Portal.Core.DTO.News.AdminsNewsDetailesToShowDTO;
    if (dto == null)
    {
        <div class="admin-sidebar">
            <div class="card mb-3 shadow-sm">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <strong class="mb-0">@(isBangla ? "এডমিন" : "Admin")</strong>
                    <small class="text-muted">@(isBangla ? "আপনার কাজ পরিচালনা করুন" : "Manage your work")</small>
                </div>
                <div class="card-body">
                    <div class="text-muted">@(isBangla ? "কোনো সংবাদ নির্বাচিত হয়নি।" : "No news selected.")</div>
                </div>
            </div>
        </div>
    }
    else
    {
        Func<NewsStatus, string> badgeClass = s => s switch
        {
            NewsStatus.Pending => "bg-secondary",
            NewsStatus.Published => "bg-success",
            NewsStatus.Rejected => "bg-danger",
            NewsStatus.Hidden => "bg-dark",
            NewsStatus.Blacklisted => "bg-warning text-dark",
            _ => "bg-secondary"
        };


        if (dto != null)
        {
            <div class="admin-sidebar">
                <div class="card mb-3 shadow-sm">
                    <div class="card-header d-flex align-items-center justify-content-between">
                        <strong class="mb-0">@(isBangla ? "এডমিন" : "Admin")</strong>
                        <small class="text-muted">@(isBangla ? "আপনার কাজ পরিচালনা করুন" : "Manage your work")</small>
                    </div>

                    <div class="card-body">
                        <div class="mb-3">
                            <h6 class="mb-1">@(isBangla ? "বর্তমান" : "Current")</h6>
                            <div>
                                @if(isBangla)
                                {
                                    <span id="newsStatusBadge" class="badge @badgeClass(dto.NewsStatus)">@dto.NewsStatus.GetDisplayName()</span>
                                    <span id="newsPriorityBadge" class="badge ms-2">@dto.NewsPriority.GetDisplayName()</span>
                                    <span id="newsTypeBadge" class="badge ms-2">@dto.NewsType.GetDisplayName()</span>
                                    
                                }
                                else
                                {
                                    <span id="newsStatusBadge" class="badge @badgeClass(dto.NewsStatus)">@dto.NewsStatus</span>
                                    <span id="newsPriorityBadge" class="badge ms-2">@dto.NewsPriority</span>
                                    <span id="newsTypeBadge" class="badge ms-2">@dto.NewsType</span>
                                }
                                
                            </div>
                        </div>

                        <div class="mb-3">
                            <h6 class="mb-2">@(isBangla ? "স্ট্যাটাস পরিবর্তন" : "Change Status")</h6>
                            <div id="changeStatusContainer" class="d-flex flex-wrap gap-2">
                                @foreach (NewsStatus status in Enum.GetValues(typeof(NewsStatus)))
                                {
                                    if (status == dto.NewsStatus) { continue; }

                                    <form method="post"
                                          asp-area="Admin"
                                          asp-controller="AdminActions"
                                          asp-action="ChangeNewsStatus"
                                          class="d-inline ajax-change-status">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="newsId" value="@dto.NewsId" />
                                        <input type="hidden" name="newStatus" value="@status" />
                                        <button type="submit" class="btn btn-sm btn-outline-secondary" title="@(isBangla ? ("স্ট্যাটাস পরিবর্তন করুন: " + status.GetDisplayName()) : ("Change status to " + status))">
                                            <span class="badge rounded-pill @badgeClass(status) me-1">@(isBangla? status.GetDisplayName() : status)</span>
                                            @(isBangla ? "নির্ধারণ" : "Set")
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>

                        <div class="mb-3">
                            <h6 class="mb-2">@(isBangla ? "প্রায়োরিটি পরিবর্তন" : "Change Priority")</h6>
                            <form method="post"
                                  asp-area="Admin"
                                  asp-controller="AdminActions"
                                  asp-action="ChangeNewsPriority"
                                  class="ajax-change-priority">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="newsId" value="@dto.NewsId" />
                                <div class="input-group">
                                    <select name="newPriority" class="form-select form-select-sm" aria-label="@(isBangla ? "প্রায়োরিটি পরিবর্তন" : "Change priority")">
                                        @foreach (NewsPriority p in Enum.GetValues(typeof(NewsPriority)))
                                        {
                                            if(isBangla)
                                            {
                                                <option value="@p" selected="@(p == dto.NewsPriority)">@p.GetDisplayName()</option>

                                            }
                                            else
                                            {
                                                <option value="@p" selected="@(p == dto.NewsPriority)">@p</option>
                                            }
                                        }
                                    </select>
                                    <button type="submit" class="btn btn-sm btn-primary" title="@(isBangla ? "প্রায়োরিটি আপডেট করুন" : "Update priority")">
                                        <i class="bi bi-arrow-repeat"></i>
                                    </button>
                                </div>
                            </form>
                        </div>

                        <div class="mb-3">
                            <h6 class="mb-2">@(isBangla ? "টাইপ পরিবর্তন" : "Change Type")</h6>
                            <form method="post"
                                  asp-area="Admin"
                                  asp-controller="AdminActions"
                                  asp-action="ChangeNewsType"
                                  class="ajax-change-type">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="newsId" value="@dto.NewsId" />
                                <div class="input-group">
                                    <select name="newType" class="form-select form-select-sm" aria-label="@(isBangla ? "টাইপ পরিবর্তন" : "Change type")">
                                        @foreach (NewsType t in Enum.GetValues(typeof(NewsType)))
                                        {
                                            if(isBangla)
                                            {
                                                <option value="@t" selected="@(t == dto.NewsType)">@t.GetDisplayName()</option>

                                            }
                                            else
                                            {
                                                <option value="@t" selected="@(t == dto.NewsType)">@t</option>
                                            }
                                            
                                        }
                                    </select>
                                    <button type="submit" class="btn btn-sm btn-primary" title="@(isBangla ? "টাইপ আপডেট করুন" : "Update type")">
                                        <i class="bi bi-arrow-repeat"></i>
                                    </button>
                                </div>
                            </form>
                        </div>

                        <div class="mb-3">
                            <h6 class="mb-2">@(isBangla ? "পিন" : "Pin")</h6>
                            
                        @if (isPinned)
                        {
                            <form method="post" asp-area="Admin" asp-controller="AdminActions" asp-action="UnpinNews" class="d-inline ajax-toggle-pin">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="newsId" value="@dto.NewsId" />
                                <button type="submit" class="btn btn-sm btn-outline-warning" title="@(isBangla ? "পিন সরান" : "Unpin this news")">
                                    <i class="bi bi-pin-angle-fill me-1"></i> @(isBangla ? "পিন সরান" : "Unpin")
                                </button>
                            </form>
                        }
                        else
                        {
                            <form method="post" asp-area="Admin" asp-controller="AdminActions" asp-action="PinNews" class="d-inline ajax-toggle-pin">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="newsId" value="@dto.NewsId" />
                                <button type="submit" class="btn btn-sm btn-outline-primary" title="@(isBangla ? "এই সংবাদ পিন করুন" : "Pin this news")">
                                    <i class="bi bi-pin-angle me-1"></i> @(isBangla ? "এই সংবাদ পিন করুন" : "Pin This News")
                                </button>
                            </form>
                        }
                    
                        </div>

                        <div class="mb-3">
                            <h6 class="mb-2 text-danger">@(isBangla ? "মুছুন" : "Delete")</h6>
                            <form method="post"
                                  asp-area="Admin"
                                  asp-controller="AdminActions"
                                  asp-action="DeleteNewsPermanently"
                                  asp-route-returnUrl="@ViewBag.PreviousUrl"
                                  class="ajax-delete-news"
                                  onsubmit="@(isBangla ? "return confirm('এই সংবাদ স্থায়ীভাবে মুছে ফেলবেন? এই কাজ পূর্বাবস্থায় ফেরানো যাবে না।');" : "return confirm('Permanently delete this news? This action cannot be undone.');")">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="newsId" value="@dto.NewsId" />
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="@(isBangla ? "স্থায়ীভাবে মুছে ফেলুন" : "Delete permanently")">
                                    <i class="bi bi-trash me-1"></i> @(isBangla ? "স্থায়ীভাবে মুছুন" : "Delete Permanently")
                                </button>
                            </form>
                            <div class="small text-muted mt-1">@(isBangla ? "এই ক্রিয়া সংবাদটি স্থায়ীভাবে সরিয়ে ফেলবে।" : "This action removes the news permanently.")</div>
                        </div>

                    </div>
                </div>
            </div>


           
        }
    }
}
