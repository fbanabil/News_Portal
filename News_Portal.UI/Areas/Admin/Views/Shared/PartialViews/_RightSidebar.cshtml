@model SideBarDTO


@if (ViewBag.Title == "Admin Actions")
{

    <div class="admin-sidebar">
        <div class="card mb-3 shadow-sm">
            <div class="card-header d-flex align-items-center justify-content-between">
                <strong class="mb-0">Admins</strong>
                <small class="text-muted">Manage by email</small>
            </div>

            <div class="card-body">
                <form id="addAdminForm" method="post" asp-area="Admin" asp-controller="AdminActions" asp-action="AddAuthor" class="mb-3" role="form" novalidate>
                    @Html.AntiForgeryToken()
                    <label class="form-label visually-hidden" for="AddAuthor_Email">Add author by email</label>
                    <div class="input-group">
                        <input asp-for="authorAddRemoveDTO.AddEmail" class="form-control" placeholder="author@example.com" aria-label="Author email" />
                        <button type="submit" class="btn btn-primary" title="Add author">
                            <i class="bi bi-person-plus"></i>
                        </button>
                    </div>
                    <span asp-validation-for="authorAddRemoveDTO.AddEmail" class="text-danger"></span>
                </form>

                <form id="removeAdminForm" method="post" asp-area="Admin" asp-controller="AdminActions" asp-action="RemoveAuthor" class="mb-2" role="form" novalidate>
                    @Html.AntiForgeryToken()
                    <label class="form-label visually-hidden" for="RemoveAuthor_Email">Remove author by email</label>
                    <div class="input-group">
                        <select asp-for="authorAddRemoveDTO.RemoveEmail" class="form-control" asp-items="@ViewBag.AuthorsList">
                            <option value="">-- Select Author --</option>
                        </select>
                        <span asp-validation-for="authorAddRemoveDTO.RemoveEmail" class="text-danger"></span>
                        <button type="submit" class="btn btn-outline-danger" title="Remove Author">
                            <i class="bi bi-person-dash"></i>
                        </button>
                    </div>
                    @* <span asp-validation-for="RemoveEmail" class="text-danger" ></span> *@
                </form>

                <div class="mt-2 text-muted small">
                    Use email addresses to add or remove author users. Bulk management is available on the full author users page.
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header d-flex align-items-center justify-content-between">
                <strong class="mb-0">Status Filters</strong>
                <small class="text-muted">Visibility</small>
            </div>

            <div class="card-body">
                @{
                    Func<NewsStatus, string> badgeClass = s => s switch
                    {
                        NewsStatus.Pending => "bg-secondary",
                        NewsStatus.Published => "bg-success",
                        NewsStatus.Rejected => "bg-danger",
                        NewsStatus.Hidden => "bg-dark",
                        NewsStatus.Blacklisted => "bg-warning text-dark",
                        _ => "bg-secondary"
                    };
                }

                <div class="list-group list-group-flush mb-3">
                    <a asp-area="Admin"
                       asp-controller="AdminActions"
                       asp-action="Index"
                       asp-route-newsstatus=""
                       class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        <span class="me-2">All</span>
                    </a>
                    @foreach (NewsStatus status in Enum.GetValues(typeof(NewsStatus)))
                    {
                        <a asp-area="Admin"
                           asp-controller="AdminActions"
                           asp-action="Index"
                           asp-route-newsstatus="@status"
                           class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                            <span class="me-2">@status</span>
                            <span class="badge rounded-pill @badgeClass(status)">@status</span>
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>

}
else
{
    <div class="admin-sidebar">
        <div class="card mb-3 shadow-sm">
            <div class="card-header d-flex align-items-center justify-content-between">
                <strong class="mb-0">Admin</strong>
                <small class="text-muted">Manage your work</small>
            </div>
        </div>
    </div>
}



