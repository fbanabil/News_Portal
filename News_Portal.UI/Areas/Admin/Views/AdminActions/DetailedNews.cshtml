@using News_Portal.Core.DTO.Comment
@model AdminsNewsDetailesToShowDTO

@{
    var lang = Context.Request.Cookies["Language"];
    if (lang == null) lang = Languages.Bangla.ToString();
    bool isBangla = (lang == Languages.Bangla.ToString()) ? true : false;
}
@{
    ViewData["Title"] = isBangla ? "সংবাদ বিস্তারিত" : "News Details";
    ViewBag.Title = ViewData["Title"];
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    SideBarDTO sideBarDTO=new SideBarDTO();
}


@{
    var galleryId = $"newsGallery_{Model.NewsId}";
    var authorName = Model.Author?.UserName ?? "Unknown";
    var commentsCount = Model.Comments?.Count ?? 0;

    var contentLines = (Model.NewsContent ?? string.Empty)
        .Split(new[] { "\r\n", "\n" }, StringSplitOptions.RemoveEmptyEntries)
        .Select(l => l.Trim())
        .Where(l => !string.IsNullOrWhiteSpace(l))
        .ToList();

    string? youtubeEmbedUrl = Model.VideoUrl;
    var hasVideo = !string.IsNullOrWhiteSpace(youtubeEmbedUrl);
    var hasImages = Model.Images?.Any() == true;
    var totalMediaItems = (hasImages ? Model.Images!.Count : 0) + (hasVideo ? 1 : 0);

    string? youtubeVideoId = null;
    if (hasVideo && youtubeEmbedUrl!.Contains("youtube.com/embed/"))
    {
        var parts = youtubeEmbedUrl.Split('/');
        youtubeVideoId = parts.LastOrDefault()?.Split('?').FirstOrDefault();
    }

    var previousUrl = Context.Request.Headers["Referer"].ToString();
    ViewBag.PreviousUrl = !string.IsNullOrWhiteSpace(previousUrl) ? previousUrl : Url.Action("Index", "AdminActions", new { area = "Admin" });

    bool isPinned = ViewBag.IsPinned ?? false;
}


@await Html.PartialAsync("PartialViews/MessagePartial")


<div class="author-news-main">

        <main class="main-content">
            <header class="news-hero">
                <div class="news-meta-bar">
                    <div class="meta-left">
                    <span class="news-category">@(isBangla? Model.NewsType.GetDisplayName() : Model.NewsType)</span>
                    <span class="news-badge status-badge">@(isBangla? Model.NewsStatus.GetDisplayName() : Model.NewsStatus)</span>
                    <span class="news-badge priority-badge">@(isBangla? Model.NewsPriority.GetDisplayName() : Model.NewsPriority)</span>
                    </div>

                    <div class="news-dates">
                        <span class="published-date">
                            <i class="bi bi-calendar3"></i>
                        @(isBangla ? "প্রকাশিত " + Model.PublishedDate.GetBengaliDate() : "Published " + Model.PublishedDate.ToString("MMM dd, yyyy"))
                        </span>
                        <span class="updated-date">
                            <i class="bi bi-clock-history"></i>
                        @(isBangla ? "আপডেট হয়েছে " + Model.LastUpdate.GetBengaliDate() : "Updated at" + Model.LastUpdate.ToString("MMM dd, yyyy HH:mm"))
                        </span>
                    </div>
                </div>

                <h1 class="news-title">@Model.NewsTitle</h1>

                <div class="news-stats-bar">
                    <div class="author-info">
                        <i class="bi bi-person-circle"></i>
                        <span class="author-name">@authorName</span>
                    </div>
                    <div class="article-stats">
                        <span class="views-count">
                            <i class="bi bi-eye"></i>
                        @(isBangla ? "দেখা হয়েছে " + @Model.TotalViews.ToString("N0").ToBanglaDigits() : "Viewed " + @Model.TotalViews.ToString("N0")))
                            
                        </span>
                        <span class="comments-info">
                            <i class="bi bi-chat-dots"></i>
                        <span id="comments-count">@(isBangla? commentsCount.ToString().ToBanglaDigits() : commentsCount)</span> comments
                        </span>
                    </div>
                </div>
            </header>

            @if (totalMediaItems > 0)
            {
                @if (totalMediaItems > 1)
                {
                    <div id="@galleryId"
                         class="carousel slide mb-3 rounded overflow-hidden shadow-sm media-carousel"
                         data-bs-ride="carousel"
                         data-bs-interval="2000"
                         data-bs-pause="false">

                        <div class="carousel-inner">
                            @{
                                var slideIndex = 0;
                            }

                            @if (hasVideo)
                            {
                                <div class="carousel-item @(slideIndex == 0 ? "active" : "") video-slide">
                                    <div class="ratio ratio-16x9">
                                        <iframe src="@youtubeEmbedUrl?enablejsapi=1&origin=@(Context.Request.Scheme)://@(Context.Request.Host)"
                                                title="YouTube video"
                                                frameborder="0"
                                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                                                referrerpolicy="strict-origin-when-cross-origin"
                                                allowfullscreen
                                                class="carousel-video"
                                                id="youtube-player-@youtubeVideoId">
                                        </iframe>
                                    </div>
                                </div>
                                slideIndex++;
                            }

                            @if (hasImages)
                            {
                                @foreach (var img in Model.Images!)
                                {
                                    <div class="carousel-item @(slideIndex == 0 ? "active" : "") image-slide">
                                        <div class="ratio ratio-16x9">
                                            <img src="@img.ImageUrl"
                                                 class="d-block w-100 object-fit-cover carousel-image"
                                                 alt="@Model.NewsTitle image @(slideIndex + 1)"
                                                 loading="lazy" />
                                        </div>
                                    </div>
                                    slideIndex++;
                                }
                            }
                        </div>

                        <button class="carousel-control-prev" type="button"
                                data-bs-target="#@galleryId" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">@(isBangla ?"পূর্ববর্তী": "Previous")</span>
                        </button>
                        <button class="carousel-control-next" type="button"
                                data-bs-target="#@galleryId" data-bs-slide="next">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">@(isBangla? "পরবর্তী" : "Next")</span>
                        </button>

                        <div class="auto-slide-control">
                            <button type="button" class="btn btn-sm auto-slide-toggle" id="autoSlideToggle">
                                <i class="bi bi-pause-fill"></i>
                            </button>
                        </div>

                        <div class="video-status-indicator d-none" id="videoStatusIndicator">
                            <i class="bi bi-play-circle-fill me-2"></i>
                        <span>@(isBangla ? "ভিডিও চলছে" : "Video Playing")</span>
                        </div>
                    </div>
                }
                else
                {
                    <div class="single-media mb-3 rounded overflow-hidden shadow-sm border">
                        <div class="ratio ratio-16x9">
                            @if (hasVideo)
                            {
                                <iframe src="@youtubeEmbedUrl"
                                        title="YouTube video"
                                        frameborder="0"
                                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                                        referrerpolicy="strict-origin-when-cross-origin"
                                        allowfullscreen>
                                </iframe>
                            }
                            else if (hasImages)
                            {
                                var img = Model.Images!.First();
                                <img src="@img.ImageUrl"
                                     class="w-100 object-fit-cover"
                                     alt="@Model.NewsTitle" />
                            }
                        </div>
                    </div>
                }

                <article class="news-article card border-0 shadow-sm flex-grow-1">
                    <div class="card-body p-3 p-md-4 news-article-scroll">
                        @if (contentLines.Count == 0)
                        {
                            <p class="text-muted mb-0">@(isBangla? "কোন নিউজ নেই।":" No content available.")</p>
                        }
                        else
                        {
                            foreach (var line in contentLines)
                            {
                            <p class="fs-6 lh-base mb-3">@(isBangla? line.ToString().ToBanglaDigits() : line)</p>
                            }
                        }
                    </div>
                    @* <div class="article-footer">
                        <button type="button"
                                class="btn btn-outline-primary btn-comments"
                                data-bs-toggle="modal"
                                data-bs-target="#commentsModal">
                            <i class="bi bi-chat-dots me-2"></i>
                            View Comments
                            (<span id="comments-toggle-count">@commentsCount</span>)
                        </button>
                    </div> *@
                </article>
            }
        </main>


        @* <aside class="sidebar">
            <div class="sidebar-section">
                @await Html.PartialAsync("PartialViews/_RightSidebar")
            </div>
        </aside> *@

   
</div>



@section Scripts {
    <script>
        (function () {
            const form = document.getElementById("comment-form");
            const commentsContainer = document.getElementById("comments-container");
            const commentsCount = document.getElementById("comments-count");
            const commentsCountModal = document.getElementById("comments-count-modal");
            const commentsToggleCount = document.getElementById("comments-toggle-count");
            const textarea = document.getElementById("CommentText");
            const submitBtn = document.getElementById("submit-btn");
            const commentsModal = document.getElementById("commentsModal");

            const mediaCarousel = document.querySelector('.media-carousel');
            if (mediaCarousel) {
                const carousel = bootstrap.Carousel.getOrCreateInstance(mediaCarousel, {
                    interval: 2000,
                    ride: 'carousel',
                    pause: false,
                    wrap: true
                });

                const autoSlideToggle = document.getElementById('autoSlideToggle');
                const videoStatusIndicator = document.getElementById('videoStatusIndicator');
                let isAutoSliding = true;
                let isVideoPlaying = false;
                let wasAutoSlidingBeforeVideo = true;
                let youtubePlayer = null;
                let playerReady = false;

                window.onYouTubeIframeAPIReady = function() {
                    const videoIframe = document.querySelector('iframe[src*="youtube.com"]');
                    if (videoIframe) {
                        const videoId = videoIframe.src.match(/embed\/([^?]+)/)?.[1];
                        if (videoId) {
                            youtubePlayer = new YT.Player(videoIframe, {
                                events: {
                                    'onReady': onPlayerReady,
                                    'onStateChange': onPlayerStateChange
                                }
                            });
                        }
                    }
                };

                function onPlayerReady(event) {
                    playerReady = true;
                }

                function onPlayerStateChange(event) {
                    if (event.data === YT.PlayerState.PLAYING) {
                        if (!isVideoPlaying) {
                            isVideoPlaying = true;
                            wasAutoSlidingBeforeVideo = isAutoSliding;
                            carousel.pause();
                            if (videoStatusIndicator) {
                                videoStatusIndicator.classList.remove('d-none');
                            }
                        }
                    } else if (event.data === YT.PlayerState.PAUSED || 
                               event.data === YT.PlayerState.ENDED || 
                               event.data === YT.PlayerState.CUED) {
                        if (isVideoPlaying) {
                            isVideoPlaying = false;
                            if (videoStatusIndicator) {
                                videoStatusIndicator.classList.add('d-none');
                            }
                            if (wasAutoSlidingBeforeVideo && isAutoSliding) {
                                carousel.cycle();
                            }
                        }
                    }
                }

                if (document.querySelector('iframe[src*="youtube.com"]')) {
                    const tag = document.createElement('script');
                    tag.src = 'https://www.youtube.com/iframe_api';
                    const firstScriptTag = document.getElementsByTagName('script')[0];
                    firstScriptTag.parentNode.insertBefore(tag, firstScriptTag);
                }

                if (autoSlideToggle) {
                    autoSlideToggle.addEventListener('click', function () {
                        if (isAutoSliding) {
                            carousel.pause();
                            autoSlideToggle.innerHTML = '<i class="bi bi-play-fill"></i>';
                            autoSlideToggle.setAttribute('title', 'Resume auto-slide');
                            isAutoSliding = false;
                        } else {
                            if (!isVideoPlaying) {
                                carousel.cycle();
                            }
                            autoSlideToggle.innerHTML = '<i class="bi bi-pause-fill"></i>';
                            autoSlideToggle.setAttribute('title', 'Pause auto-slide');
                            isAutoSliding = true;
                        }
                    });
                }

                mediaCarousel.addEventListener('slide.bs.carousel', function () {
                    if (isVideoPlaying) {
                        isVideoPlaying = false;
                        if (videoStatusIndicator) {
                            videoStatusIndicator.classList.add('d-none');
                        }
                        
                        if (youtubePlayer && playerReady) {
                            youtubePlayer.pauseVideo();
                        }
                        
                        if (wasAutoSlidingBeforeVideo && isAutoSliding) {
                            setTimeout(() => carousel.cycle(), 100);
                        }
                    }
                });

                document.addEventListener('keydown', function (e) {
                    if (mediaCarousel.matches(':hover')) {
                        if (e.key === 'ArrowLeft') {
                            e.preventDefault();
                            carousel.prev();
                        } else if (e.key === 'ArrowRight') {
                            e.preventDefault();
                            carousel.next();
                        } else if (e.key === ' ') {
                            e.preventDefault();
                            autoSlideToggle?.click();
                        }
                    }
                });

                mediaCarousel.addEventListener('mouseenter', function () {
                    if (isAutoSliding && !isVideoPlaying) {
                        carousel.pause();
                    }
                });

                mediaCarousel.addEventListener('mouseleave', function () {
                    if (isAutoSliding && !isVideoPlaying) {
                        carousel.cycle();
                    }
                });
            }

            if (form && textarea && submitBtn) {
                form.addEventListener("submit", async function (e) {
                    e.preventDefault();
                    if (!textarea.value.trim()) return;

                    const originalText = submitBtn.innerHTML;
                    submitBtn.innerHTML = '<i class="bi bi-hourglass-split"></i>';
                    submitBtn.disabled = true;

                    const formData = new FormData(form);

                    try {
                        const response = await fetch(form.action, { method: "POST", body: formData });
                        if (!response.ok) return;

                        const newCommentHtml = await response.text();

                        let commentsList = document.getElementById("comments-list");
                        const noCommentsAlert = document.getElementById("no-comments-alert");

                        if (noCommentsAlert) {
                            noCommentsAlert.remove();
                            commentsList = document.createElement("div");
                            commentsList.id = "comments-list";
                            commentsContainer.appendChild(commentsList);
                        }

                        if (commentsList) commentsList.insertAdjacentHTML("afterbegin", newCommentHtml);
                        textarea.value = "";

                        const current = parseInt(commentsCount?.textContent || "0");
                        const next = current + 1;
                        if (commentsCount) commentsCount.textContent = next;
                        if (commentsCountModal) commentsCountModal.textContent = next;
                        if (commentsToggleCount) commentsToggleCount.textContent = next;

                        const newComment = commentsList?.firstElementChild;
                        if (newComment) {
                            newComment.classList.add('new-comment-animation');
                            setTimeout(() => newComment.classList.remove('new-comment-animation'), 1000);
                        }
                    } catch (err) {
                        console.error("Error posting comment:", err);
                    } finally {
                        submitBtn.innerHTML = originalText;
                        submitBtn.disabled = false;
                    }
                });
            }

            if (textarea) {
                textarea.addEventListener('input', function () {
                    this.style.height = 'auto';
                    this.style.height = Math.min(this.scrollHeight, 120) + 'px';
                });
            }

            if (commentsModal && textarea) {
                commentsModal.addEventListener('shown.bs.modal', function () {
                    textarea.focus();
                });
            }
        })();
        
    </script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    <partial name="_ValidationScriptsPartial" />
}

