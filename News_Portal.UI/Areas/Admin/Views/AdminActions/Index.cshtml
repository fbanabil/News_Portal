@model AdminNewsAllFiltersDTO
@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}
@using News_Portal.Core.Enums
@{
    var lang = Context.Request.Cookies["Language"];
    if (lang == null) lang = Languages.Bangla.ToString();
    bool isBangla = (lang == Languages.Bangla.ToString()) ? true : false;
}
@{


    string L(string en, string bn) => isBangla ? bn : en;

    ViewBag.Title = isBangla ? "এডমিনের কাজ" : "Admin Actions";

    Model.parametersDTO ??= new NewsFilterParametersDTO();

    if (Model.pageNo <= 0) Model.pageNo = 1;
    if (Model.pageSize <= 0) Model.pageSize = 10;
    Model.sortBy ??= "PublishedDate";

    int pageCount = ViewBag.PageCount ?? 1;
    // string presentStatus = ViewBag.PresentStatus;
    NewsStatus? newsStatusFilter = Model.parametersDTO.NewsStatus;

    string currentUrl = Context.Request.Path + Context.Request.QueryString;


}

@await Html.PartialAsync("PartialViews/MessagePartial")



<div class="author-news-main">
    <main class="main-content">
        <div class="section-header">
            <h2 class="section-title">
                <i class="bi bi-pencil-square"></i>
                @L("Admin Dashboard", "এডমিন ড্যাশবোর্ড")
            </h2>
        </div>

        <div class="author-news-content">

            <div class="filters-container">
                <form method="get"
                      asp-area="Admin"
                      asp-controller="AdminActions"
                      asp-action="Index"
                      class="filters-form"
                      id="filtersForm">

                    <div class="filter-header">
                        <h4 class="filter-title">
                            <i class="bi bi-funnel"></i>
                            @L("Filter & Search Articles", "ফিল্টার ও নিবন্ধ অনুসন্ধান")
                        </h4>
                        <button type="button" class="btn-toggle-filters" id="btnToggleFilters" aria-expanded="false" aria-controls="filterFields" onclick="toggleFilters()">
                            <i class="bi bi-chevron-down" aria-hidden="true"></i>
                        </button>
                    </div>

                    <div class="filter-fields" id="filterFields">

                        <div class="filter-row">
                            <div class="filter-group">
                                <label asp-for="parametersDTO.NewsTitle" class="filter-label">
                                    <i class="bi bi-search"></i>
                                    @L("Article Title", "শিরোনাম")
                                </label>
                                <input asp-for="parametersDTO.NewsTitle"
                                       class="filter-input"
                                       placeholder="@(L("Search by title...", "শিরোনামে অনুসন্ধান..."))"
                                       value="@Model.parametersDTO?.NewsTitle" />
                            </div>

                            <div class="filter-group">
                                <label asp-for="parametersDTO.NewsContent" class="filter-label">
                                    <i class="bi bi-text-paragraph"></i>
                                    @L("Content", "বিষয়বস্তু")
                                </label>
                                <input asp-for="parametersDTO.NewsContent"
                                       class="filter-input"
                                       placeholder="@(L("Search in content...", "বিষয়বস্তুতে অনুসন্ধান..."))"
                                       value="@Model.parametersDTO?.NewsContent" />
                            </div>
                        </div>

                        <div class="filter-row">
                            <div class="filter-group">
                                <label asp-for="parametersDTO.NewsType" class="filter-label">
                                    <i class="bi bi-tags"></i>
                                    @L("Category", "বিভাগ")
                                </label>
                                <select asp-for="parametersDTO.NewsType" class="filter-select">
                                    <option value="">@(L("All Categories", "সব বিভাগ"))</option>
                                    @foreach (NewsType newsType in Enum.GetValues<NewsType>())
                                    {
                                        if(isBangla)
                                        {
                                            <option value="@newsType" selected="@(Model.parametersDTO?.NewsType == newsType)">
                                                @newsType.GetDisplayName()
                                            </option>
                                        }
                                        else
                                        {
                                            <option value="@newsType" selected="@(Model.parametersDTO?.NewsType == newsType)">
                                                @newsType
                                            </option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="filter-group">
                                <label asp-for="AuthorEmail" class="filter-label">
                                    <i class="bi bi-envelope"></i>
                                    @L("Author Email", "লেখকের ইমেইল")
                                </label>
                                @*<input asp-for="AuthorEmail"
                                       class="filter-input"
                                       placeholder="Search by author email..."
                                       value="@Model.AuthorEmail" />
                                <span asp-validation-for="AuthorEmail" class="text-danger"></span>*@
                                <select asp-for="AuthorEmail" class="filter-input" asp-items="@ViewBag.AuthorsList">
                                    <option value="">@(L("-- Select Author --", "-- লেখক নির্বাচন করুন --"))</option>
                                </select>
                                <span asp-validation-for="AuthorEmail" class="text-danger"></span>

                            </div>
                        </div>

                        <div class="filter-row">
                            <div class="filter-group">
                                <label asp-for="parametersDTO.NewsPriority" class="filter-label">
                                    <i class="bi bi-exclamation-triangle"></i>
                                    @L("Priority", "অগ্রাধিকার")
                                </label>
                                <select asp-for="parametersDTO.NewsPriority" class="filter-select">
                                    <option value="">@(L("All Priorities", "সব অগ্রাধিকার"))</option>
                                    @foreach (NewsPriority priority in Enum.GetValues<NewsPriority>())
                                    {

                                        if(isBangla)
                                        {
                                            <option value="@priority" selected="@(Model.parametersDTO?.NewsPriority == priority)">
                                                @priority.GetDisplayName()
                                            </option>
                                        }
                                        else
                                        {
                                            <option value="@priority" selected="@(Model.parametersDTO?.NewsPriority == priority)">
                                                @priority
                                            </option>
                                        }                                       
                                    }
                                </select>
                            </div>


                            <div class="filter-group">
                                <label asp-for="parametersDTO.PublishedDate" class="filter-label">
                                    <i class="bi bi-calendar-event"></i>
                                    @L("Published Date", "প্রকাশের তারিখ")
                                </label>
                                <input asp-for="parametersDTO.PublishedDate"
                                       type="date"
                                       class="filter-input"
                                       value="@Model.parametersDTO?.PublishedDate?.ToString("yyyy-MM-dd")" />
                            </div>
                        </div>

                        <div class="filter-row">
                            <div class="filter-group">
                                <label asp-for="sortBy" class="filter-label">
                                    <i class="bi bi-sort-down"></i>
                                    @L("Sort By", "বাছাইকরণ")
                                </label>
                                <select asp-for="sortBy" class="filter-select">
                                    @foreach (SortBy sortBy in Enum.GetValues<SortBy>())
                                    {
                                        if(isBangla)
                                        {
                                            <option value="@sortBy.ToString()" selected="@(Model.sortBy == sortBy.ToString())">
                                                @sortBy.GetDisplayName()
                                            </option>
                                        }
                                        else
                                        {
                                            <option value="@sortBy.ToString()" selected="@(Model.sortBy == sortBy.ToString())">
                                                @sortBy.ToString()
                                            </option>
                                        }

                                    }
                                    @*<option value="PublishedDate" selected="@(Model.sortBy == "PublishedDate")">@(L("Published Date","প্রকাশের তারিখ"))</option>
                                    <option value="NewsTitle" selected="@(Model.sortBy == "NewsTitle")">@(L("Title","শিরোনাম"))</option>
                                    <option value="TotalViews" selected="@(Model.sortBy == "TotalViews")">@(L("Total Views","মোট ভিউ"))</option>
                                    <option value="NewsStatus" selected="@(Model.sortBy == "NewsStatus")">@(L("Status","অবস্থা"))</option>
                                    <option value="NewsPriority" selected="@(Model.sortBy == "NewsPriority")">@(L("Priority","অগ্রাধিকার"))</option>
                                    <option value="NewsType" selected="@(Model.sortBy == "NewsType")">@(L("Category","বিভাগ"))</option>*@
                                </select>
                            </div>

                            <div class="filter-group">
                                <label asp-for="sortType" class="filter-label">
                                    <i class="bi bi-arrow-up-down"></i>
                                    @L("Sort Order", "সাজানোর ক্রম")
                                </label>
                                <select asp-for="sortType" class="filter-select">
                                    @foreach (SortTypes sortType in Enum.GetValues<SortTypes>())
                                    {
                                        <option value="@sortType" selected="@(Model.sortType == sortType)">
                                            @sortType.GetDisplayName()
                                        </option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="filter-row">
                            <div class="filter-group">
                                <label asp-for="pageSize" class="filter-label">
                                    <i class="bi bi-list-ol"></i>
                                    @L("Items Per Page", "প্রতি পৃষ্ঠায় আইটেম")
                                </label>
                                <select asp-for="pageSize" class="filter-select" id="pageSizeSelect">
                                    <option value="5" selected="@(Model.pageSize == 5)">5</option>
                                    <option value="10" selected="@(Model.pageSize == 10)">10</option>
                                    <option value="20" selected="@(Model.pageSize == 20)">20</option>
                                    <option value="50" selected="@(Model.pageSize == 50)">50</option>
                                </select>
                            </div>
                            <div>
                                <input type="hidden" asp-for="parametersDTO.NewsStatus" />
                            </div>

                            <div class="filter-group filter-actions">
                                <input type="hidden" asp-for="pageNo" value="@Model.pageNo" id="pageNoHidden" />

                                <button type="submit" class="btn-filter-apply">
                                    <i class="bi bi-search"></i>
                                    @L("Apply Filters", "ফিল্টার প্রয়োগ")
                                </button>

                                <a asp-area="Admin"
                                   asp-controller="AdminActions"
                                   asp-action="Index"
                                   class="btn-filter-reset">
                                    <i class="bi bi-arrow-clockwise"></i>
                                    @L("Reset", "রিসেট")
                                </a>
                            </div>
                        </div>

                    </div>
                </form>
            </div>

            <div class="articles-section">
                <div class="articles-header">
                    <h3>📰 @L("News Articles", "সংবাদ")</h3>
                    <div class="articles-summary">
                        <span class="current-filters">
                            @L("Sorted by", "ক্রম করা")  @(isBangla ? (@Model.sortType.GetDisplayName()) + " " + (Model.sortBy.GetSortBy()) + " দ্বারা" : (Model.sortBy.GetSortByInEng() + " " + (@Model.sortType)))
                            | @Model.pageSize @L("items per page", "আইটেম প্রতি পৃষ্ঠা")
                            | @L("Page", "পৃষ্ঠা") @Model.pageNo @L("of", "থেকে") @pageCount
                        </span>
                    </div>
                </div>

                <div class="articles-list" id="adminNewsHost">
                    @await Component.InvokeAsync("AdminNews", new {
                    AdminNewsFilterParametersDTO = Model.parametersDTO,
                                        authorEmail = Model.AuthorEmail,
                                        sortBy = Model.sortBy,
                                        sortOptions = Model.sortType,
                                        pageNo = Model.pageNo,
                                        pageSize = Model.pageSize
                                        
                                        })
                </div>

                <div class="pagination-wrapper" id="paginationSection">
                    @if (pageCount > 1)
                    {
                        <nav class="pagination-nav" aria-label="Article pagination">
                            <ul class="pagination-enhanced">
                                @if (Model.pageNo > 2)
                                {
                                    <li class="page-item">
                                        <button onclick="goToPageWithScroll(1)" class="page-link" title="@(L("First Page","প্রথম পাতা"))">
                                            <i class="bi bi-chevron-double-left"></i>
                                            @L("First","প্রথম")
                                        </button>
                                    </li>
                                }

                                @if (Model.pageNo > 1)
                                {
                                    <li class="page-item">
                                        <button onclick="goToPageWithScroll(@(Model.pageNo - 1))" class="page-link" title="@(L("Previous Page","পূর্ববর্তী পাতা"))">
                                            <i class="bi bi-chevron-left"></i>
                                            @L("Previous","পূর্ববর্তী")
                                        </button>
                                    </li>
                                }

                                @{
                                    int startPage = Math.Max(1, Model.pageNo - 2);
                                    int endPage = Math.Min(pageCount, Model.pageNo + 2);
                                }

                                @if (startPage > 1)
                                {
                                    <li class="page-item">
                                        <button onclick="goToPageWithScroll(1)" class="page-link">@(isBangla?"১":"1")</button>
                                    </li>
                                    @if (startPage > 2)
                                    {
                                        <li class="page-item disabled">
                                            <span class="page-link">...</span>
                                        </li>
                                    }
                                }

                                @for (int i = startPage; i <= endPage; i++)
                                {
                                    <li class="page-item @(i == Model.pageNo ? "active" : "")">
                                        @if (i == Model.pageNo)
                                        {
                                            <span class="page-link">@i</span>
                                        }
                                        else
                                        {
                                            <button onclick="goToPageWithScroll(@i)" class="page-link">@(isBangla?i.ToString().ToBanglaDigits():i)</button>
                                        }
                                    </li>
                                }

                                @if (endPage < pageCount)
                                {
                                    @if (endPage < pageCount - 1)
                                    {
                                        <li class="page-item disabled">
                                            <span class="page-link">...</span>
                                        </li>
                                    }
                                    <li class="page-item">
                                        <button onclick="goToPageWithScroll(@pageCount)" class="page-link">@(isBangla? pageCount.ToString().ToBanglaDigits() : pageCount)</button>
                                    </li>
                                }

                                @if (Model.pageNo < pageCount)
                                {
                                    <li class="page-item">
                                        <button onclick="goToPageWithScroll(@(Model.pageNo + 1))" class="page-link" title="@(L("Next Page","পরবর্তী পাতা"))">
                                            @L("Next","পরবর্তী")
                                            <i class="bi bi-chevron-right"></i>
                                        </button>
                                    </li>
                                }

                                @if (Model.pageNo < pageCount - 1)
                                {
                                    <li class="page-item">
                                        <button onclick="goToPageWithScroll(@pageCount)" class="page-link" title="@(L("Last Page","শেষ পাতা"))">
                                            @L("Last","শেষ")
                                            <i class="bi bi-chevron-double-right"></i>
                                        </button>
                                    </li>
                                }
                            </ul>
                        </nav>


                    }
                </div>

            </div>

        </div>
    </main>


</div>

@section Scripts {
    <script>
        const isBangla = @(isBangla.ToString().ToLower());

        function t(en, bn) { return isBangla ? bn : en; }

        function toggleFilters() {
            const filterFields = document.getElementById('filterFields');
            const toggleBtn = document.getElementById('btnToggleFilters');
            const toggleIcon = document.querySelector('#btnToggleFilters i');

            if (!filterFields || !toggleBtn) return;

            const isOpen = filterFields.classList.contains('show');

            if (!isOpen) {
                filterFields.classList.add('show');
                filterFields.style.display = 'block';
                filterFields.style.overflow = 'hidden';
                const fullHeight = filterFields.scrollHeight + 'px';
                filterFields.style.maxHeight = '0px';
                requestAnimationFrame(() => {
                    filterFields.style.transition = 'max-height 260ms ease';
                    filterFields.style.maxHeight = fullHeight;
                });

                toggleIcon.className = 'bi bi-chevron-up';
                toggleBtn.setAttribute('aria-expanded', 'true');
            } else {
                filterFields.style.maxHeight = filterFields.scrollHeight + 'px';
                requestAnimationFrame(() => {
                    filterFields.style.transition = 'max-height 200ms ease';
                    filterFields.style.maxHeight = '0px';
                });

                filterFields.addEventListener('transitionend', function handler() {
                    filterFields.style.display = 'none';
                    filterFields.style.maxHeight = '';
                    filterFields.style.transition = '';
                    filterFields.style.overflow = '';
                    filterFields.classList.remove('show');
                    filterFields.removeEventListener('transitionend', handler);
                });

                toggleIcon.className = 'bi bi-chevron-down';
                toggleBtn.setAttribute('aria-expanded', 'false');
            }
        }

        async function goToPageWithScroll(pageNo) {
            showLoadingIndicator();

            try {
                await scrollToPercentage(10);

                await goToPage(pageNo);

            } catch (error) {
                console.error('Error navigating to page:', error);
                showError(t('Failed to load page. Please try again.', 'পৃষ্ঠা লোড করতে ব্যর্থ হয়েছে। দয়া করে আবার চেষ্টা করুন।'));
            } finally {
                hideLoadingIndicator();
            }
        }

        function scrollToPercentage(percentage) {
            return new Promise((resolve) => {
                const documentHeight = document.documentElement.scrollHeight;
                const windowHeight = window.innerHeight;
                const targetPosition = (documentHeight - windowHeight) * (percentage / 100);

                window.scrollTo({
                    top: Math.max(0, targetPosition),
                    behavior: 'smooth'
                });

                setTimeout(resolve, 500);
            });
        }

        async function goToPage(pageNo) {
            const host = document.getElementById('adminNewsHost');
            if (!host) return;

            const pageNoHidden = document.getElementById('pageNoHidden');
            if (pageNoHidden) pageNoHidden.value = pageNo;

             const params = new URLSearchParams(window.location.search);
            params.set('pageNo', pageNo);

            const url = '@Url.Action("AdminNewsList", "AdminActions", new { area = "Admin" })' + '?' + params.toString();

            const response = await fetch(url, {
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });

            if (!response.ok) {
                throw new Error('Failed to fetch page data');
            }

            host.innerHTML = await response.text();

            const newUrl = window.location.pathname + '?' + params.toString();
            window.history.replaceState({}, '', newUrl);

            updatePaginationControls(pageNo, @pageCount);
        }

        function updatePaginationControls(currentPage, totalPages) {
            const pageInfo = document.querySelector('.pagination-summary');
            if (pageInfo) {
                const pageSize = @Model.pageSize;
                const totalItems = @(ViewBag.TotalItems ?? Model.pageSize * pageCount);
                const startItem = (currentPage - 1) * pageSize + 1;
                const endItem = Math.min(currentPage * pageSize, totalItems);

                pageInfo.innerHTML = t('Showing <strong>' + startItem + '</strong> to <strong>' + endItem + '</strong> of <strong>' + totalItems + '</strong> articles',
                                       'দেখানো হচ্ছে <strong>' + startItem + '</strong> থেকে <strong>' + endItem + '</strong> মোট <strong>' + totalItems + '</strong> টি সংবাদ');
            }

            const paginationNav = document.querySelector('.pagination-enhanced');
            if (!paginationNav) return;

            let html = '';

            if (currentPage > 2) {
                html += `<li class="page-item">
                            <button onclick="goToPageWithScroll(1)" class="page-link" title="${t('First Page','প্রথম পাতা')}">
                                <i class="bi bi-chevron-double-left"></i> ${t('First','প্রথম')}
                            </button>
                         </li>`;
            }

            if (currentPage > 1) {
                html += `<li class="page-item">
                            <button onclick="goToPageWithScroll(${currentPage - 1})" class="page-link" title="${t('Previous Page','পূর্ববর্তী পাতা')}">
                                <i class="bi bi-chevron-left"></i> ${t('Previous','পূর্ববর্তী')}
                            </button>
                         </li>`;
            }

            const startPage = Math.max(1, currentPage - 2);
            const endPage = Math.min(totalPages, currentPage + 2);

            if (startPage > 1) {
                html += `<li class="page-item">
                            <button onclick="goToPageWithScroll(1)" class="page-link">1</button>
                         </li>`;
                if (startPage > 2) {
                    html += `<li class="page-item disabled"><span class="page-link">...</span></li>`;
                }
            }

            for (let i = startPage; i <= endPage; i++) {
                if (i === currentPage) {
                    html += `<li class="page-item active"><span class="page-link">${i}</span></li>`;
                } else {
                    html += `<li class="page-item">
                                <button onclick="goToPageWithScroll(${i})" class="page-link">${i}</button>
                             </li>`;
                }
            }

            if (endPage < totalPages) {
                if (endPage < totalPages - 1) {
                    html += `<li class="page-item disabled"><span class="page-link">...</span></li>`;
                }
                html += `<li class="page-item">
                            <button onclick="goToPageWithScroll(${totalPages})" class="page-link">${totalPages}</button>
                         </li>`;
            }

            if (currentPage < totalPages) {
                html += `<li class="page-item">
                            <button onclick="goToPageWithScroll(${currentPage + 1})" class="page-link" title="${t('Next Page','পরবর্তী পাতা')}">
                                ${t('Next','পরবর্তী')} <i class="bi bi-chevron-right"></i>
                            </button>
                         </li>`;
            }

            if (currentPage < totalPages - 1) {
                html += `<li class="page-item">
                            <button onclick="goToPageWithScroll(${totalPages})" class="page-link" title="${t('Last Page','শেষ পাতা')}">
                                ${t('Last','শেষ')} <i class="bi bi-chevron-double-right"></i>
                            </button>
                         </li>`;
            }

            paginationNav.innerHTML = html;
        }

        async function changePageSize() {
            const pageSize = document.getElementById('pageSizeSelect').value;
            const params = new URLSearchParams(window.location.search);
            params.set('pageSize', pageSize);
            params.set('pageNo', '1'); 

            window.location.href = window.location.pathname + '?' + params.toString();
        }

        function showLoadingIndicator() {
            const paginationWrapper = document.querySelector('.pagination-wrapper');
            if (paginationWrapper) {
                paginationWrapper.style.opacity = '0.6';
                paginationWrapper.style.pointerEvents = 'none';
            }

            const spinner = document.createElement('div');
            spinner.id = 'pagination-loading';
            spinner.innerHTML = `
                <div style="display: flex; justify-content: center; align-items: center; padding: 20px;">
                    <div style="width: 30px; height: 30px; border: 3px solid #f3f3f3; border-top: 3px solid #667eea; border-radius: 50%; animation: spin 1s linear infinite;"></div>
                    <span style="margin-left: 10px; color: #667eea;">${t('Loading...','লোড হচ্ছে...')}</span>
                </div>

            `;

            const articlesSection = document.querySelector('.articles-list');
            if (articlesSection) {
                articlesSection.appendChild(spinner);
            }
        }

        function hideLoadingIndicator() {
            const paginationWrapper = document.querySelector('.pagination-wrapper');
            if (paginationWrapper) {
                paginationWrapper.style.opacity = '1';
                paginationWrapper.style.pointerEvents = 'auto';
            }

            const spinner = document.getElementById('pagination-loading');
            if (spinner) {
                spinner.remove();
            }
        }

        function showError(message) {
            const errorAlert = document.createElement('div');
            errorAlert.className = 'alert error-alert';
            errorAlert.innerHTML = `
                ⚠ ${message}
                <button type="button" class="alert-close" onclick="this.parentElement.remove()">×</button>
            `;

            const mainContent = document.querySelector('.main-content');
            if (mainContent) {
                mainContent.insertBefore(errorAlert, mainContent.firstChild);
                setTimeout(() => errorAlert.remove(), 5000);
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            const filterFields = document.getElementById('filterFields');
            const toggleBtn = document.getElementById('btnToggleFilters');

            if (filterFields) {
                filterFields.style.display = 'none';
                filterFields.style.overflow = 'hidden';
                filterFields.style.maxHeight = '0px';
                filterFields.classList.remove('show');
            }
            if (toggleBtn) {
                toggleBtn.setAttribute('aria-expanded', 'false');
                const icon = toggleBtn.querySelector('i');
                if (icon) icon.className = 'bi bi-chevron-down';
            }
        });
    </script>
}