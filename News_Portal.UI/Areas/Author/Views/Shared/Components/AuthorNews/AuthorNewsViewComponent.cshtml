@model List<AuthorsNewsToShowDTO>
@{
    var lang = Context.Request.Cookies["Language"];
    if (lang == null) lang = Languages.Bangla.ToString();
    bool isBangla = (lang == Languages.Bangla.ToString()) ? true : false;
}
@{
    int pageCount = ViewBag.PageCount ?? 1;
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalCount = ViewBag.TotalCount ?? Model?.Count ?? 0;
}

<div class="author-news-container">
    <div class="news-header">
        <div class="news-stats">
            <h2 class="news-title">@(isBangla ? "আপনার সংবাদ নিবন্ধসমূহ" : "Your News Articles")</h2>
            <div class="news-count">
                <span class="count-number">@(isBangla?totalCount.ToString().ToBanglaDigits(): totalCount)</span>
                <span class="count-label">@(isBangla ? "সংবাদ" : "articles found")</span>
            </div>
        </div>
    </div>

    <div class="news-content">
        @if (Model != null && Model.Any())
        {
            <div class="news-list">
                @foreach (var newsItem in Model)
                {
                    @await Html.PartialAsync("~/Areas/Author/Views/Shared/PartialViews/AuthorNewsCard.cshtml", newsItem)
                }
            </div>

            @if (pageCount > 1)
            {
              
            }
        }
        else
        {
            <div class="empty-state">
                <div class="empty-icon">
                    <svg width="64" height="64" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                              d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                </div>
                <h3 class="empty-title">@(isBangla ? "কোনো সংবাদ পাওয়া যায়নি" : "No articles found")</h3>
                <p class="empty-message">@(isBangla ? "ফিল্টার পরিবর্তন করে দেখুন অথবা আপনার প্রথম সংবাদ নিবন্ধ তৈরি করুন।" : "Try adjusting your filters or create your first news article.")</p>
                <a href="@Url.Action("AddNews", "AuthorActions", new { area = "Author" })" class="btn-create" title="@(isBangla ? "নতুন সংবাদ তৈরি করুন" : "Create New Article")">
                    <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                    </svg>
                    @(isBangla ? "নতুন সংবাদ তৈরি করুন" : "Create New Article")
                </a>
            </div>
        }
    </div>

    <div class="loading-state" id="loadingState" style="display: none;">
        <div class="loading-spinner">
            <div class="spinner"></div>
        </div>
        <p>@(isBangla ? "সংবাদ লোড হচ্ছে..." : "Loading articles...")</p>
    </div>
</div>
