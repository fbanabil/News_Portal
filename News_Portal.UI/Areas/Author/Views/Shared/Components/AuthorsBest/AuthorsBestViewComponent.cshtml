@model List<HomePageNewsToShowDTO>
@{
    var lang = Context.Request.Cookies["Language"];
    if (lang == null) lang = Languages.Bangla.ToString();
    bool isBangla = (lang == Languages.Bangla.ToString()) ? true : false;
}

<div class="row g-2 g-md-3 mt-2">
    @if (Model is { Count: > 0 })
    {
        foreach (var news in Model)
        {
            <div class="col-12">
                @await Html.PartialAsync("~/Areas/Author/Views/Shared/PartialViews/TopNewsNewsCard.cshtml", news)
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="alert alert-light border mb-0">@(isBangla? "কোন শীর্ষ সংবাদ নেই" : " No Top News available.")</div>
        </div>
    }
</div>

