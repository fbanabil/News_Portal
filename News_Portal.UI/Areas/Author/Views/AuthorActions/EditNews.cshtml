@model NewsToEditDTO
@using News_Portal.Core.Enums

@{
    var lang = Context.Request.Cookies["Language"];
    if (lang == null) lang = Languages.Bangla.ToString();
    bool isBangla = (lang == Languages.Bangla.ToString()) ? true : false;
}
@{
    ViewData["Title"] = isBangla? "সম্পাদনা করি" : "Edit News";
}



@await Html.PartialAsync("PartialViews/MessagePartial")




<div class="add-news-main">
    <div class="add-news-container">

        <main class="main-content">
            <div class="form-header">
                <div class="form-title-section">
                    <h1 class="form-title">
                        <i class="bi bi-pencil-square me-2"></i>
                        @(isBangla ? "সংবাদ সম্পাদনা করুন" : "Edit News Article")
                    </h1>
                    <p class="form-subtitle">@(isBangla ? "আপনার সংবাদ নিবন্ধের বিবরণ ও বিষয়বস্তু হালনাগাদ করুন" : "Update your news article details and content")</p>
                </div>
            </div>

            <form asp-controller="AuthorActions" asp-action="EditNews" method="post" enctype="multipart/form-data" class="add-news-form">
                @Html.AntiForgeryToken()
                <input asp-for="NewsId" type="hidden" />

                <div asp-validation-summary="All" class="validation-summary"></div>

                <div class="form-content">

                    <div class="form-group">
                        <label asp-for="NewsTitle" class="form-label">
                            <i class="bi bi-type me-1"></i>
                            @(isBangla ? "নিউজ শিরোনাম *" : "News Title *")
                        </label>
                        <input asp-for="NewsTitle"
                               type="text"
                               class="form-control"
                               placeholder="@(isBangla ? "আকর্ষণীয় শিরোনাম লিখুন..." : "Enter a compelling news title...")"
                               maxlength="100" />
                        <span asp-validation-for="NewsTitle" class="text-danger"></span>
                        <small class="form-text">@(isBangla ? "সর্বোচ্চ ১০০ অক্ষর" : "Maximum 100 characters")</small>
                    </div>

                    <div class="form-group">
                        <label asp-for="NewsContent" class="form-label">
                            <i class="bi bi-file-text me-1"></i>
                            @(isBangla ? "সংবাদ বিষয়বস্তু *" : "News Content *")
                        </label>
                        <textarea asp-for="NewsContent"
                                  class="form-control content-textarea"
                                  rows="12"
                                  placeholder="@(isBangla ? "এখানে আপনার সংবাদ বিষয়বস্তু লিখুন..." : "Write your news article content here...")"></textarea>
                        <span asp-validation-for="NewsContent" class="text-danger"></span>
                        <small class="form-text">@(isBangla ? "সংবাদ বিষয়বস্তুর বিস্তারিত লিখুন" : "Provide detailed information about the news story")</small>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label asp-for="NewsType" class="form-label">
                                <i class="bi bi-tag me-1"></i>
                                @(isBangla ? "সংবাদের ধরন *" : "News Type *")
                            </label>
                            <select asp-for="NewsType" class="form-select">
                                @foreach (var newsType in Enum.GetValues<NewsType>())
                                {
                                    if (newsType.ToString() != "General")
                                    {
                                        <option value="@newsType">@(isBangla ? newsType.GetDisplayName() : newsType)</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="NewsType" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="NewsPriority" class="form-label">
                                <i class="bi bi-exclamation-triangle me-1"></i>
                                @(isBangla ? "প্রাধান্য *" : "Priority *")
                            </label>
                            <select asp-for="NewsPriority" class="form-select">
                                @foreach (var priority in Enum.GetValues<NewsPriority>())
                                {
                                    <option value="@priority">@(isBangla ? priority.GetDisplayName() : priority)</option>
                                }
                            </select>
                            <span asp-validation-for="NewsPriority" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="VideoUrl" class="form-label">
                            <i class="bi bi-camera-video me-1"></i>
                            @(isBangla ? "ভিডিও URL (ঐচ্ছিক)" : "Video URL (Optional)")
                        </label>
                        <input asp-for="VideoUrl"
                               type="url"
                               class="form-control"
                               placeholder="@(isBangla ? "https://youtube.com/embed/your-video-id" : "https://youtube.com/embed/your-video-id")" />
                        <span asp-validation-for="VideoUrl" class="text-danger"></span>
                        <small class="form-text">@(isBangla ? "ভিডিও সহ যুক্ত করতে YouTube embed URL দিন" : "Add a YouTube embed URL to include video content")</small>
                    </div>

                    @if (Model.ExistingImages != null && Model.ExistingImages.Any())
                    {
                        <div class="form-group">
                            <label class="form-label">
                                <i class="bi bi-images me-1"></i>
                                @(isBangla ? "বর্তমান ছবি" : "Current Images")
                            </label>

                            <div class="existing-images-container">
                                <div class="existing-images-grid" id="existingImagesGrid">
                                    @{int i = 0;}
                                    @foreach (var image in Model.ExistingImages)
                                    {
                                        <div class="existing-image-item" data-image-id="@image.ImageId">
                                            <div class="image-wrapper">
                                                <img src="@image.ImageUrl" alt="News Image" class="existing-image" />
                                                <div class="image-overlay">
                                                    <button type="button"
                                                            class="btn btn-danger btn-sm remove-image-btn"
                                                            onclick="removeExistingImage('@image.ImageId')">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </div>
                                            </div>

                                            <div class="image-info">
                                                <small class="image-url text-muted">@image.ImageUrl</small>
                                            </div>

                                            <input type="hidden" class="existing-hidden imageid"
                                                   name="ExistingImages[@i].ImageId" value="@image.ImageId" />
                                            <input type="hidden" class="existing-hidden imageurl"
                                                   name="ExistingImages[@i].ImageUrl" value="@image.ImageUrl" />
                                        </div>
                                        i++;
                                    }
                                </div>

                                <small class="form-text">
                                    @(isBangla ? "ছবি মুছে দিতে ট্র্যাশ আইকনে ক্লিক করুন। সেভ করলে মুছে ফেলা হবে।" : "Click the trash icon to remove images. Removed images will be deleted when you save.")
                                </small>
                            </div>
                        </div>
                    }

                    <div class="form-group">
                        <label asp-for="NewImages" class="form-label">
                            <i class="bi bi-plus-circle me-1"></i>
                            @(isBangla ? "নতুন ছবি যোগ করুন (ঐচ্ছিক)" : "Add New Images (Optional)")
                        </label>
                        <div class="image-upload-wrapper" id="imageUploadWrapper">
                            <input asp-for="NewImages"
                                   type="file"
                                   class="image-input"
                                   multiple
                                   accept="image/*"
                                   id="imageInput"
                                   onchange="handleNewImages(this)" />
                            <div class="image-upload-info">
                                <i class="bi bi-cloud-upload"></i>
                                <span>@(isBangla ? "ছবি নির্বাচন করতে ক্লিক করুন অথবা এখানে ড্র্যাগ করতে পারেন" : "Click to select images or drag and drop")</span>
                                <small>@(isBangla ? "সর্বোচ্চ ৪ টি ছবি (JPG, PNG, GIF)" : "Maximum 4 images (JPG, PNG, GIF)")</small>
                            </div>
                        </div>
                        <span asp-validation-for="NewImages" class="text-danger"></span>
                        <div class="image-count-display" id="imageCount" style="display: none;">
                            <small class="text-muted">@(isBangla ? "নির্বাচিত: " : "Selected: ")<span id="selectedCount">0</span>/@(isBangla ? "৪" : "4") @(isBangla ? "ছবি" : "images")</small>
                        </div>
                    </div>

                    <div class="selected-files-container" id="selectedFiles" style="display: none;">
                        <h6 class="selected-files-title">
                            <i class="bi bi-file-earmark-image me-1"></i>
                            @(isBangla ? "নতুন ছবি নির্বাচিত" : "New Images Selected")
                        </h6>
                        <div class="selected-files-list" id="selectedFilesList"></div>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary btn-submit" id="submitBtn">
                            <i class="bi bi-check-lg me-2"></i>
                            @(isBangla ? "নিবন্ধ আপডেট করুন" : "Update Article")
                        </button>
                        <a href="@Url.Action("DetailedNews", "AuthorActions", new { area = "Author", newsId = Model.NewsId })"
                           class="btn btn-secondary">
                            <i class="bi bi-arrow-left me-2"></i>
                            @(isBangla ? "বাতিল" : "Cancel")
                        </a>
                    </div>

                </div>
            </form>
        </main>

        <aside class="sidebar">
            <div class="sidebar-section">
                <h4 class="sidebar-title">
                    <i class="bi bi-lightbulb"></i>
                    @(isBangla ? "সম্পাদনার নির্দেশিকা" : "Edit Guidelines")
                </h4>
                <div class="guidelines-content">
                    <div class="guideline-item">
                        <i class="bi bi-check2 text-success"></i>
                        <span>@(isBangla ? "সুস্পষ্ট এবং আকর্ষণীয় শিরোনাম লিখুন" : "Write clear and engaging titles")</span>
                    </div>
                    <div class="guideline-item">
                        <i class="bi bi-check2 text-success"></i>
                        <span>@(isBangla ? "সম্পূর্ণ বিষয়বস্তু প্রদান করুন" : "Provide comprehensive content")</span>
                    </div>
                    <div class="guideline-item">
                        <i class="bi bi-check2 text-success"></i>
                        <span>@(isBangla ? "উপযুক্ত শ্রেণি নির্বাচন করুন" : "Choose appropriate categories")</span>
                    </div>
                    <div class="guideline-item">
                        <i class="bi bi-check2 text-success"></i>
                        <span>@(isBangla ? "সঠিক প্রাধান্য নির্ধারণ করুন" : "Set correct priority levels")</span>
                    </div>
                    <div class="guideline-item">
                        <i class="bi bi-check2 text-success"></i>
                        <span>@(isBangla ? "প্রাসঙ্গিক ছবি ও ভিডিও যোগ করুন" : "Add relevant images and videos")</span>
                    </div>
                </div>
            </div>

            <div class="sidebar-section">
                <h4 class="sidebar-title">
                    <i class="bi bi-info-circle"></i>
                    @(isBangla ? "বিষয়বস্তু নির্দেশিকা" : "Content Guidelines")
                </h4>
                <div class="content-info">
                    <div class="info-item">
                        <span class="info-label">@(isBangla ? "শিরোনাম:" : "Title:")</span>
                        <span class="info-value">@(isBangla ? "সর্বোচ্চ ১০০ অক্ষর" : "Maximum 100 characters")</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">@(isBangla ? "বিষয়বস্তু:" : "Content:")</span>
                        <span class="info-value">@(isBangla ? "বর্ণনামূলক ও তথ্যবহুল লিখুন" : "Be descriptive and informative")</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">@(isBangla ? "ছবি:" : "Images:")</span>
                        <span class="info-value">@(isBangla ? "সর্বোচ্চ ৪ নতুন ছবি (JPG, PNG, GIF)" : "Maximum 4 new images (JPG, PNG, GIF)")</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">@(isBangla ? "ভিডিও:" : "Video:")</span>
                        <span class="info-value">@(isBangla ? "শুধুমাত্র YouTube URL" : "YouTube URLs only")</span>
                    </div>
                </div>
            </div>

            <div class="sidebar-section">
                <h4 class="sidebar-title">
                    <i class="bi bi-lightning"></i>
                    @(isBangla ? "দ্রুত কার্যক্রম" : "Quick Actions")
                </h4>
                <div class="quick-actions">
                    <a href="@Url.Action("Index", "AuthorActions", new { area = "Author" })"
                       class="action-btn primary">
                        <i class="bi bi-list"></i>
                        @(isBangla ? "আমার নিবন্ধসমূহ দেখুন" : "View My Articles")
                    </a>
                    <button type="button" class="action-btn secondary" onclick="resetForm()">
                        <i class="bi bi-arrow-clockwise"></i>
                        @(isBangla ? "পরিবর্তন রিসেট করুন" : "Reset Changes")
                    </button>
                </div>
            </div>

            <div class="sidebar-section">
                <h4 class="sidebar-title">
                    <i class="bi bi-graph-up"></i>
                    @(isBangla ? "নিবন্ধ পরিসংখ্যান" : "Article Statistics")
                </h4>
                <div class="tips-content">
                    <div class="tip-item">
                        <strong>@(isBangla ? "ছবি ব্যবস্থাপনা:" : "Image Management:")</strong>
                        <p>@(isBangla ? "অপ্রয়োজনীয় ছবি মুছতে ট্র্যাশ আইকনে ক্লিক করুন।" : "Remove unwanted images by clicking the trash icon. Add new images using the file selector above.")</p>
                    </div>
                    <div class="tip-item">
                        <strong>@(isBangla ? "প্রাধান্য সেটিং:" : "Priority Setting:")</strong>
                        <p>@(isBangla ? "উচ্চ প্রাধান্য পৃষ্ঠার হোমে প্রাধান্য পায়।" : "High priority articles appear prominently on the homepage.")</p>
                    </div>
                </div>
            </div>
        </aside>

    </div>
</div>

@section Scripts {
    <script>
        // Client-side localization & settings
        const isBangla = @(isBangla.ToString().ToLower());
        const texts = {
            maxImages: '@(isBangla ? "৪" : "4")',
            maxImagesEn: @(4),
            overMaxSelected: isBangla
                ? (allowed => `আপনি সর্বোচ্চ ${texts.maxImages} টি ছবি নির্বাচন করতে পারবেন। প্রথম ${allowed} টি ছবি যোগ করা হবে।`)
                : (allowed => `You can only select up to ${texts.maxImagesEn} images. Only the first ${allowed} image(s) will be added.`),
            alreadyAtMax: isBangla
                ? 'আপনি ইতোমধ্যে সর্বোচ্চ সংখ্যক ছবি নির্বাচন করেছেন।'
                : 'You have already selected the maximum number of images.',
            updating: isBangla ? 'আপডেট করা হচ্ছে...' : 'Updating...',
            removeFileTitle: isBangla ? 'ফাইল সরান' : 'Remove file',
            confirmReset: isBangla ? 'আপনি নিশ্চিত যে আপনি সব পরিবর্তন রিসেট করতে চান? এটি মূল মানগুলো পুনঃস্থাপন করবে।' : 'Are you sure you want to reset all changes? This will restore the original values.',
            removeFileBtnTitle: isBangla ? 'ফাইল সরান' : 'Remove file'
        };

        let selectedFiles = [];
        const maxImages = 4;

        document.addEventListener('DOMContentLoaded', function () {
            if ($('.field-validation-error:not(:empty)').length > 0) {
                $('.validation-summary').show();
            }

            const textarea = document.querySelector('.content-textarea');
            if (textarea) {
                textarea.addEventListener('input', function () {
                    this.style.height = 'auto';
                    this.style.height = Math.min(this.scrollHeight, 400) + 'px';
                });

                textarea.style.height = 'auto';
                textarea.style.height = Math.min(textarea.scrollHeight, 400) + 'px';
            }

            const form = document.querySelector('.add-news-form');
            const submitBtn = document.getElementById('submitBtn');

            if (form && submitBtn) {
                form.addEventListener('submit', function (e) {
                    const originalText = submitBtn.innerHTML;
                    submitBtn.innerHTML = `<i class="bi bi-hourglass-split me-2"></i> ${texts.updating}`;
                    submitBtn.disabled = true;

                    setTimeout(() => {
                        submitBtn.innerHTML = originalText;
                        submitBtn.disabled = false;
                    }, 5000);
                });
            }

            const titleInput = document.querySelector('input[name="NewsTitle"]');
            if (titleInput) {
                const maxLength = titleInput.getAttribute('maxlength');
                const charCountElement = document.createElement('small');
                charCountElement.className = 'char-count';
                titleInput.parentNode.appendChild(charCountElement);

                function updateCharCount() {
                    const remaining = maxLength - titleInput.value.length;
                    if (isBangla) {
                        // Use server-side converter for digits if required
                        const rem = remaining.toString();
                        charCountElement.textContent = `${rem.ToBanglaDigits ? rem.ToBanglaDigits() : rem} ${remaining === 1 ? 'অক্ষর বাকি' : 'অক্ষর বাকি'}`;
                        charCountElement.className = remaining < 20 ? 'char-count text-warning' : 'char-count text-muted';
                    } else {
                        charCountElement.textContent = `${remaining} characters remaining`;
                        charCountElement.className = remaining < 20 ? 'char-count text-warning' : 'char-count text-muted';
                    }
                }

                titleInput.addEventListener('input', updateCharCount);
                updateCharCount();
            }

            initializeImageUpload();
        });

        function initializeImageUpload() {
            const imageInput = document.getElementById('imageInput');
            const wrapper = document.getElementById('imageUploadWrapper');
            const selectedFilesContainer = document.getElementById('selectedFiles');
            const selectedFilesList = document.getElementById('selectedFilesList');
            const imageCount = document.getElementById('imageCount');
            const selectedCount = document.getElementById('selectedCount');

            if (!imageInput || !wrapper) return;

            ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
                wrapper.addEventListener(eventName, preventDefaults, false);
                document.body.addEventListener(eventName, preventDefaults, false);
            });

            ['dragenter', 'dragover'].forEach(eventName => {
                wrapper.addEventListener(eventName, highlight, false);
            });

            ['dragleave', 'drop'].forEach(eventName => {
                wrapper.addEventListener(eventName, unhighlight, false);
            });

            wrapper.addEventListener('drop', handleDrop, false);

            function preventDefaults(e) {
                e.preventDefault();
                e.stopPropagation();
            }

            function highlight(e) {
                wrapper.classList.add('drag-over');
            }

            function unhighlight(e) {
                wrapper.classList.remove('drag-over');
            }

            function handleDrop(e) {
                const dt = e.dataTransfer;
                const files = dt.files;
                handleFiles(Array.from(files));
            }

            function handleFiles(files) {
                const imageFiles = files.filter(file => file.type.startsWith('image/'));
                const totalFiles = selectedFiles.length + imageFiles.length;

                if (totalFiles > maxImages) {
                    const allowedFiles = maxImages - selectedFiles.length;
                    if (allowedFiles > 0) {
                        alert(isBangla
                            ? `আপনি সর্বোচ্চ ${texts.maxImages} টি ছবি নির্বাচন করতে পারবেন। প্রথম ${allowedFiles} টি ছবি যোগ করা হবে।`
                            : `You can only select up to ${texts.maxImagesEn} images. Only the first ${allowedFiles} image(s) will be added.`);
                        imageFiles.splice(allowedFiles);
                    } else {
                        alert(isBangla ? texts.alreadyAtMax : texts.alreadyAtMax);
                        return;
                    }
                }

                selectedFiles = selectedFiles.concat(imageFiles);
                updateFilesDisplay();
                updateFileInput();
            }

            function updateFilesDisplay() {
                if (selectedFiles.length > 0) {
                    selectedFilesContainer.style.display = 'block';
                    imageCount.style.display = 'block';
                    selectedCount.textContent = isBangla ? selectedFiles.length.toString().ToBanglaDigits?.() ?? selectedFiles.length : selectedFiles.length;
                    selectedFilesList.innerHTML = '';

                    selectedFiles.forEach((file, index) => {
                        const fileItem = document.createElement('div');
                        fileItem.className = 'selected-file-item';
                        fileItem.innerHTML = `
                            <div class="file-info">
                                <i class="bi bi-file-earmark-image file-icon"></i>
                                <div class="file-details">
                                    <span class="file-name">${file.name}</span>
                                    <small class="file-size text-muted">${formatFileSize(file.size)}</small>
                                </div>
                            </div>
                            <button type="button" class="remove-file-btn" onclick="removeFile(${index})" title="${texts.removeFileTitle}">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        `;
                        selectedFilesList.appendChild(fileItem);
                    });
                } else {
                    selectedFilesContainer.style.display = 'none';
                    imageCount.style.display = 'none';
                    selectedFilesList.innerHTML = '';
                }
            }

            function updateFileInput() {
                const dt = new DataTransfer();
                selectedFiles.forEach(file => dt.items.add(file));
                imageInput.files = dt.files;
            }
        }

        function handleNewImages(input) {
            const files = Array.from(input.files);
            handleFiles(files);

            function handleFiles(files) {
                const imageFiles = files.filter(file => file.type.startsWith('image/'));

                if (imageFiles.length > maxImages) {
                    alert(isBangla
                        ? `আপনি সর্বোচ্চ ${texts.maxImages} টি ছবি নির্বাচন করতে পারবেন। প্রথম ${texts.maxImages} টি ছবি প্রক্রিয়াকৃত হবে।`
                        : `You can only select up to ${texts.maxImagesEn} images. Only the first ${texts.maxImagesEn} image(s) will be processed.`);
                    imageFiles.splice(maxImages);
                }

                selectedFiles = imageFiles;
                updateFilesDisplay();
            }

            function updateFilesDisplay() {
                const selectedFilesContainer = document.getElementById('selectedFiles');
                const selectedFilesList = document.getElementById('selectedFilesList');
                const imageCount = document.getElementById('imageCount');
                const selectedCount = document.getElementById('selectedCount');

                if (selectedFiles.length > 0) {
                    selectedFilesContainer.style.display = 'block';
                    imageCount.style.display = 'block';
                    selectedCount.textContent = isBangla ? selectedFiles.length.toString().ToBanglaDigits?.() ?? selectedFiles.length : selectedFiles.length;
                    selectedFilesList.innerHTML = '';

                    selectedFiles.forEach((file, index) => {
                        const fileItem = document.createElement('div');
                        fileItem.className = 'selected-file-item';
                        fileItem.innerHTML = `
                            <div class="file-info">
                                <i class="bi bi-file-earmark-image file-icon"></i>
                                <div class="file-details">
                                    <span class="file-name">${file.name}</span>
                                    <small class="file-size text-muted">${formatFileSize(file.size)}</small>
                                </div>
                            </div>
                            <button type="button" class="remove-file-btn" onclick="removeFile(${index})" title="${texts.removeFileTitle}">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        `;
                        selectedFilesList.appendChild(fileItem);
                    });
                } else {
                    selectedFilesContainer.style.display = 'none';
                    imageCount.style.display = 'none';
                }
            }
        }

        
        function removeExistingImage(imageId) {
            const imageItem = document.querySelector(`[data-image-id="${imageId}"]`);
            if (!imageItem) return;

            imageItem.style.transition = 'opacity 0.3s ease';
            imageItem.style.opacity = '0.3';
            imageItem.classList.add('removed-image');

            const hiddenInputs = imageItem.querySelectorAll('input[type="hidden"]');
            hiddenInputs.forEach(input => {
                input.disabled = true;
            });

            const overlay = imageItem.querySelector('.image-overlay');
            if (overlay) {
                overlay.innerHTML = `<span class="badge bg-danger">${isBangla ? 'মুছে ফেলা হয়েছে' : 'Removed'}</span>`;
            }

            const removeBtn = imageItem.querySelector('.remove-image-btn');
            if (removeBtn) {
                removeBtn.disabled = true;
                removeBtn.innerHTML = '<i class="bi bi-check"></i>';
            }

            reindexExistingImages();
        }

        function reindexExistingImages() {
            const items = document.querySelectorAll('#existingImagesGrid .existing-image-item');
            let idx = 0;

            items.forEach(item => {
                const hiddenId = item.querySelector('input.imageid');
                const hiddenUrl = item.querySelector('input.imageurl');
                if (!hiddenId || !hiddenUrl) return;

                if (hiddenId.disabled || hiddenUrl.disabled) return;

                hiddenId.name = `ExistingImages[${idx}].ImageId`;
                hiddenUrl.name = `ExistingImages[${idx}].ImageUrl`;
                idx++;
            });
        }

        window.removeFile = function (index) {
            selectedFiles.splice(index, 1);

            const selectedFilesContainer = document.getElementById('selectedFiles');
            const selectedFilesList = document.getElementById('selectedFilesList');
            const imageCount = document.getElementById('imageCount');
            const selectedCount = document.getElementById('selectedCount');

            if (selectedFiles.length > 0) {
                selectedCount.textContent = isBangla ? selectedFiles.length.toString().ToBanglaDigits?.() ?? selectedFiles.length : selectedFiles.length;
                selectedFilesList.innerHTML = '';

                selectedFiles.forEach((file, newIndex) => {
                    const fileItem = document.createElement('div');
                    fileItem.className = 'selected-file-item';
                    fileItem.innerHTML = `
                        <div class="file-info">
                            <i class="bi bi-file-earmark-image file-icon"></i>
                            <div class="file-details">
                                <span class="file-name">${file.name}</span>
                                <small class="file-size text-muted">${formatFileSize(file.size)}</small>
                            </div>
                        </div>
                        <button type="button" class="remove-file-btn" onclick="removeFile(${newIndex})" title="${texts.removeFileTitle}">
                            <i class="bi bi-x-lg"></i>
                        </button>
                    `;
                    selectedFilesList.appendChild(fileItem);
                });
            } else {
                selectedFilesContainer.style.display = 'none';
                imageCount.style.display = 'none';
            }

            const imageInput = document.getElementById('imageInput');
            const dt = new DataTransfer();
            selectedFiles.forEach(file => dt.items.add(file));
            imageInput.files = dt.files;
        };

        function formatFileSize(bytes) {
            if (bytes === 0) return isBangla ? '0 Bytes' : '0 Bytes';
            const k = 1024;
            const sizes = ['Bytes', 'KB', 'MB', 'GB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
        }

        function resetForm() {
            if (confirm(texts.confirmReset)) {
                location.reload();
            }
        }
    </script>

    <partial name="_ValidationScriptsPartial" />
}
