@model AuthorNewsAllFiltersDTO
@using News_Portal.Core.Enums
@{
    ViewBag.Title = "Author Actions";

    Model.parametersDTO ??= new AuthorNewsFilterParametersDTO();

    // Defaults
    if (Model.pageNo <= 0) Model.pageNo = 1;
    if (Model.pageSize <= 0) Model.pageSize = 5;
    Model.sortBy ??= "PublishedDate";

    int pageCount = ViewBag.PageCount ?? 1;
    
}

<!-- Newspaper Header -->
<header class="newspaper-header">
    <h1 class="newspaper-title">Daily News Portal</h1>
    <div class="newspaper-date">@DateTime.Now.ToString("MMMM dd, yyyy")</div>
    <div class="newspaper-line"></div>
</header>

<!-- Alerts -->
@if (TempData["Message"] != null)
{
    <div class="alert success-alert">
        ✓ @TempData["Message"]
        <button type="button" class="alert-close" onclick="this.parentElement.style.display='none'">×</button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert error-alert">
        ⚠ @TempData["Error"]
        <button type="button" class="alert-close" onclick="this.parentElement.style.display='none'">×</button>
    </div>
}

<!-- Main Layout Container -->
<div class="author-news-main">
    <div class="author-news-container">

        <!-- Main Content Section -->
        <main class="main-content">
            <div class="section-header">
                <h2 class="section-title">
                    <i class="bi bi-pencil-square"></i>
                    Author Dashboard
                </h2>
                <p class="section-subtitle">Manage your articles and track performance</p>
            </div>

            <div class="author-news-content">

                <!-- Filter Section -->
                <div class="filters-container">
                    <form method="get"
                          asp-area="Author"
                          asp-controller="AuthorActions"
                          asp-action="Index"
                          class="filters-form"
                          id="filtersForm">

                        <!-- Filter Header -->
                        <div class="filter-header">
                            <h4 class="filter-title">
                                <i class="bi bi-funnel"></i>
                                Filter & Search Articles
                            </h4>
                            <button type="button" class="btn-toggle-filters" onclick="toggleFilters()">
                                <i class="bi bi-chevron-down"></i>
                            </button>
                        </div>

                        <!-- Filter Fields -->
                        <div class="filter-fields" id="filterFields">

                            <!-- Row 1: Title and Content Search -->
                            <div class="filter-row">
                                <div class="filter-group">
                                    <label asp-for="parametersDTO.NewsTitle" class="filter-label">
                                        <i class="bi bi-search"></i>
                                        Article Title
                                    </label>
                                    <input asp-for="parametersDTO.NewsTitle"
                                           class="filter-input"
                                           placeholder="Search by title..."
                                           value="@Model.parametersDTO?.NewsTitle" />
                                </div>

                                <div class="filter-group">
                                    <label asp-for="parametersDTO.NewsContent" class="filter-label">
                                        <i class="bi bi-text-paragraph"></i>
                                        Content
                                    </label>
                                    <input asp-for="parametersDTO.NewsContent"
                                           class="filter-input"
                                           placeholder="Search in content..."
                                           value="@Model.parametersDTO?.NewsContent" />
                                </div>
                            </div>

                            <!-- Row 2: News Type and Status -->
                            <div class="filter-row">
                                <div class="filter-group">
                                    <label asp-for="parametersDTO.NewsType" class="filter-label">
                                        <i class="bi bi-tags"></i>
                                        Category
                                    </label>
                                    <select asp-for="parametersDTO.NewsType" class="filter-select">
                                        <option value="">All Categories</option>
                                        @foreach (NewsType newsType in Enum.GetValues<NewsType>())
                                        {
                                            <option value="@newsType" selected="@(Model.parametersDTO?.NewsType == newsType)">
                                                @newsType
                                            </option>
                                        }
                                    </select>
                                </div>

                                <div class="filter-group">
                                    <label asp-for="parametersDTO.NewsStatus" class="filter-label">
                                        <i class="bi bi-flag"></i>
                                        Status
                                    </label>
                                    <select asp-for="parametersDTO.NewsStatus" class="filter-select">
                                        <option value="">All Statuses</option>
                                        @foreach (NewsStatus status in Enum.GetValues<NewsStatus>())
                                        {
                                            <option value="@status" selected="@(Model.parametersDTO?.NewsStatus == status)">
                                                @status
                                            </option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <!-- Row 3: Priority and Published Date -->
                            <div class="filter-row">
                                <div class="filter-group">
                                    <label asp-for="parametersDTO.NewsPriority" class="filter-label">
                                        <i class="bi bi-exclamation-triangle"></i>
                                        Priority
                                    </label>
                                    <select asp-for="parametersDTO.NewsPriority" class="filter-select">
                                        <option value="">All Priorities</option>
                                        @foreach (NewsPriority priority in Enum.GetValues<NewsPriority>())
                                        {
                                            <option value="@priority" selected="@(Model.parametersDTO?.NewsPriority == priority)">
                                                @priority
                                            </option>
                                        }
                                    </select>
                                </div>

                                <div class="filter-group">
                                    <label asp-for="parametersDTO.PublishedDate" class="filter-label">
                                        <i class="bi bi-calendar-event"></i>
                                        Published Date
                                    </label>
                                    <input asp-for="parametersDTO.PublishedDate"
                                           type="date"
                                           class="filter-input"
                                           value="@Model.parametersDTO?.PublishedDate?.ToString("yyyy-MM-dd")" />
                                </div>
                            </div>

                            <!-- Row 4: Sorting Options -->
                            <div class="filter-row">
                                <div class="filter-group">
                                    <label asp-for="sortBy" class="filter-label">
                                        <i class="bi bi-sort-down"></i>
                                        Sort By
                                    </label>
                                    <select asp-for="sortBy" class="filter-select">
                                        <option value="PublishedDate" selected="@(Model.sortBy == "PublishedDate")">Published Date</option>
                                        <option value="NewsTitle" selected="@(Model.sortBy == "NewsTitle")">Title</option>
                                        <option value="TotalViews" selected="@(Model.sortBy == "TotalViews")">Total Views</option>
                                        <option value="NewsStatus" selected="@(Model.sortBy == "NewsStatus")">Status</option>
                                        <option value="NewsPriority" selected="@(Model.sortBy == "NewsPriority")">Priority</option>
                                        <option value="NewsType" selected="@(Model.sortBy == "NewsType")">Category</option>
                                    </select>
                                </div>

                                <div class="filter-group">
                                    <label asp-for="sortType" class="filter-label">
                                        <i class="bi bi-arrow-up-down"></i>
                                        Sort Order
                                    </label>
                                    <select asp-for="sortType" class="filter-select">
                                        @foreach (SortTypes sortType in Enum.GetValues<SortTypes>())
                                        {
                                            <option value="@sortType" selected="@(Model.sortType == sortType)">
                                                @sortType
                                            </option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <!-- Row 5: Page Size and Actions -->
                            <div class="filter-row">
                                <div class="filter-group">
                                    <label asp-for="pageSize" class="filter-label">
                                        <i class="bi bi-list-ol"></i>
                                        Items Per Page
                                    </label>
                                    <select asp-for="pageSize" class="filter-select" id="pageSizeSelect">
                                        <option value="5" selected="@(Model.pageSize == 5)">5</option>
                                        <option value="10" selected="@(Model.pageSize == 10)">10</option>
                                        <option value="20" selected="@(Model.pageSize == 20)">20</option>
                                        <option value="50" selected="@(Model.pageSize == 50)">50</option>
                                    </select>
                                </div>

                                <div class="filter-group filter-actions">
                                    <!-- pageNo must exist to submit correct page later -->
                                    <input type="hidden" asp-for="pageNo" value="@Model.pageNo" id="pageNoHidden" />

                                    <button type="submit" class="btn-filter-apply">
                                        <i class="bi bi-search"></i>
                                        Apply Filters
                                    </button>

                                    <a asp-area="Author"
                                       asp-controller="AuthorActions"
                                       asp-action="Index"
                                       class="btn-filter-reset">
                                        <i class="bi bi-arrow-clockwise"></i>
                                        Reset
                                    </a>
                                </div>
                            </div>

                        </div>
                    </form>
                </div>

                <!-- Articles List Section -->
                <div class="articles-section">
                    <div class="articles-header">
                        <h3>📰 Your Articles</h3>
                        <div class="articles-summary">
                            <span class="current-filters">
                                Sorted by @Model.sortBy (@Model.sortType)
                                | @Model.pageSize items per page
                                | Page @Model.pageNo of @pageCount
                            </span>
                        </div>
                    </div>

                    <!-- Articles List Component -->
                    <div class="articles-list" id="authorNewsHost">
                        @await Component.InvokeAsync("AuthorNews", new {
                        authorNewsFilterParametersDTO = Model.parametersDTO,
                                                sortBy = Model.sortBy,
                                                sortOptions = Model.sortType,
                                                pageNo = Model.pageNo,
                                                pageSize = Model.pageSize
                                                })
                    </div>

                    <!-- Enhanced Pagination Controls -->
                    <div class="pagination-wrapper" id="paginationSection">
                        @if (pageCount > 1)
                        {
                            <nav class="pagination-nav" aria-label="Article pagination">
                                <ul class="pagination-enhanced">
                                    <!-- First Page Button -->
                                    @if (Model.pageNo > 2)
                                    {
                                        <li class="page-item">
                                            <button onclick="goToPageWithScroll(1)" class="page-link" title="First Page">
                                                <i class="bi bi-chevron-double-left"></i>
                                                First
                                            </button>
                                        </li>
                                    }

                                    <!-- Previous Button -->
                                    @if (Model.pageNo > 1)
                                    {
                                        <li class="page-item">
                                            <button onclick="goToPageWithScroll(@(Model.pageNo - 1))" class="page-link" title="Previous Page">
                                                <i class="bi bi-chevron-left"></i>
                                                Previous
                                            </button>
                                        </li>
                                    }

                                    <!-- Page Number Buttons -->
                                    @{
                                        int startPage = Math.Max(1, Model.pageNo - 2);
                                        int endPage = Math.Min(pageCount, Model.pageNo + 2);
                                    }

                                    @if (startPage > 1)
                                    {
                                        <li class="page-item">
                                            <button onclick="goToPageWithScroll(1)" class="page-link">1</button>
                                        </li>
                                        @if (startPage > 2)
                                        {
                                            <li class="page-item disabled">
                                                <span class="page-link">...</span>
                                            </li>
                                        }
                                    }

                                    @for (int i = startPage; i <= endPage; i++)
                                    {
                                        <li class="page-item @(i == Model.pageNo ? "active" : "")">
                                            @if (i == Model.pageNo)
                                            {
                                                <span class="page-link">@i</span>
                                            }
                                            else
                                            {
                                                <button onclick="goToPageWithScroll(@i)" class="page-link">@i</button>
                                            }
                                        </li>
                                    }

                                    @if (endPage < pageCount)
                                    {
                                        @if (endPage < pageCount - 1)
                                        {
                                            <li class="page-item disabled">
                                                <span class="page-link">...</span>
                                            </li>
                                        }
                                        <li class="page-item">
                                            <button onclick="goToPageWithScroll(@pageCount)" class="page-link">@pageCount</button>
                                        </li>
                                    }

                                    <!-- Next Button -->
                                    @if (Model.pageNo < pageCount)
                                    {
                                        <li class="page-item">
                                            <button onclick="goToPageWithScroll(@(Model.pageNo + 1))" class="page-link" title="Next Page">
                                                Next
                                                <i class="bi bi-chevron-right"></i>
                                            </button>
                                        </li>
                                    }

                                    <!-- Last Page Button -->
                                    @if (Model.pageNo < pageCount - 1)
                                    {
                                        <li class="page-item">
                                            <button onclick="goToPageWithScroll(@pageCount)" class="page-link" title="Last Page">
                                                Last
                                                <i class="bi bi-chevron-double-right"></i>
                                            </button>
                                        </li>
                                    }
                                </ul>
                            </nav>

                            <!-- Pagination Info -->
                            <div class="pagination-info">
                                <div class="pagination-summary">
                                    Showing <strong>@((Model.pageNo - 1) * Model.pageSize + 1)</strong> to 
                                    <strong>@Math.Min(Model.pageNo * Model.pageSize, ViewBag.TotalItems ?? Model.pageSize * pageCount)</strong> 
                                    of <strong>@(ViewBag.TotalItems ?? Model.pageSize * pageCount)</strong> articles
                                </div>
                                
                                <div class="page-size-controls">
                                    <label for="pageSizeSelect">Items per page:</label>
                                    <select asp-for="pageSize" class="page-size-select" id="pageSizeSelect" onchange="changePageSize()">
                                        <option value="5" selected="@(Model.pageSize == 5)">5</option>
                                        <option value="10" selected="@(Model.pageSize == 10)">10</option>
                                        <option value="20" selected="@(Model.pageSize == 20)">20</option>
                                        <option value="50" selected="@(Model.pageSize == 50)">50</option>
                                    </select>
                                </div>
                            </div>
                        }
                    </div>

                </div>

            </div>
        </main>

        <!-- Right Sidebar -->
        <aside class="sidebar">

            <!-- Quick Stats Section -->
            <div class="sidebar-section">
                <h4 class="sidebar-title">
                    <i class="bi bi-graph-up"></i>
                    Quick Stats
                </h4>
                <div class="stats-grid">
                    <div class="stat-item">
                        <span class="stat-number">25</span>
                        <span class="stat-label">Total Articles</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-number">1.2K</span>
                        <span class="stat-label">Total Views</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-number">8</span>
                        <span class="stat-label">This Month</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-number">92%</span>
                        <span class="stat-label">Published</span>
                    </div>
                </div>
            </div>

            <!-- Quick Actions Section -->
            <div class="sidebar-section">
                <h4 class="sidebar-title">
                    <i class="bi bi-lightning"></i>
                    Quick Actions
                </h4>
                <div class="quick-actions">
                    <a href="#" class="action-btn primary">
                        <i class="bi bi-plus-circle"></i>
                        Create New Article
                    </a>
                    <a href="#" class="action-btn secondary">
                        <i class="bi bi-eye"></i>
                        View All Articles
                    </a>
                    <a href="#" class="action-btn primary">
                        <i class="bi bi-bar-chart"></i>
                        Analytics
                    </a>
                    <a href="#" class="action-btn secondary">
                        <i class="bi bi-gear"></i>
                        Settings
                    </a>
                </div>
            </div>

            <!-- Best Performing News Section -->
            <div class="sidebar-section">
                <h4 class="sidebar-title">
                    <i class="bi bi-trophy"></i>
                    Your Top Articles
                </h4>
                <p class="sidebar-subtitle">Most viewed articles this month</p>
                <div class="best-news-content">
                    <div class="content-placeholder">
                        <p>Your best performing articles will be displayed here.</p>
                        <small class="text-muted">Connect this to your actual data source</small>
                    </div>
                </div>
            </div>

        </aside>

    </div>
</div>

@section Scripts {
    <script>
        // Enhanced pagination with auto-scroll functionality
        async function goToPageWithScroll(pageNo) {
            // Show loading indicator
            showLoadingIndicator();
            
            try {
                // First, scroll to 10% of the page smoothly
                await scrollToPercentage(10);
                
                // Then load the new page content
                await goToPage(pageNo);
                
            } catch (error) {
                console.error('Error navigating to page:', error);
                showError('Failed to load page. Please try again.');
            } finally {
                hideLoadingIndicator();
            }
        }

        // Smooth scroll to percentage of page
        function scrollToPercentage(percentage) {
            return new Promise((resolve) => {
                const documentHeight = document.documentElement.scrollHeight;
                const windowHeight = window.innerHeight;
                const targetPosition = (documentHeight - windowHeight) * (percentage / 100);
                
                window.scrollTo({
                    top: Math.max(0, targetPosition),
                    behavior: 'smooth'
                });
                
                // Wait for scroll animation to complete
                setTimeout(resolve, 500);
            });
        }

        // Enhanced goToPage function
        async function goToPage(pageNo) {
            const host = document.getElementById('authorNewsHost');
            if (!host) return;

            // Update hidden pageNo input
            const pageNoHidden = document.getElementById('pageNoHidden');
            if (pageNoHidden) pageNoHidden.value = pageNo;

            // Get current URL parameters
            const params = new URLSearchParams(window.location.search);
            params.set('pageNo', pageNo);

            const url = '@Url.Action("AuthorNewsList", "AuthorActions", new { area = "Author" })' + '?' + params.toString();

            const response = await fetch(url, { 
                headers: { 'X-Requested-With': 'XMLHttpRequest' } 
            });
            
            if (!response.ok) {
                throw new Error('Failed to fetch page data');
            }

            // Update content
            host.innerHTML = await response.text();

            // Update URL to reflect current page
            const newUrl = window.location.pathname + '?' + params.toString();
            window.history.replaceState({}, '', newUrl);

            // Update pagination controls
            updatePaginationControls(pageNo, @pageCount);
        }

        // Enhanced pagination controls update
        function updatePaginationControls(currentPage, totalPages) {
            // Update page info
            const pageInfo = document.querySelector('.pagination-summary');
            if (pageInfo) {
                const pageSize = @Model.pageSize;
                const totalItems = @(ViewBag.TotalItems ?? Model.pageSize * pageCount);
                const startItem = (currentPage - 1) * pageSize + 1;
                const endItem = Math.min(currentPage * pageSize, totalItems);
                
                pageInfo.innerHTML = `Showing <strong>${startItem}</strong> to <strong>${endItem}</strong> of <strong>${totalItems}</strong> articles`;
            }

            // Update pagination buttons
            const paginationNav = document.querySelector('.pagination-enhanced');
            if (!paginationNav) return;

            let html = '';

            // First Page Button
            if (currentPage > 2) {
                html += `<li class="page-item">
                            <button onclick="goToPageWithScroll(1)" class="page-link" title="First Page">
                                <i class="bi bi-chevron-double-left"></i> First
                            </button>
                         </li>`;
            }

            // Previous Button
            if (currentPage > 1) {
                html += `<li class="page-item">
                            <button onclick="goToPageWithScroll(${currentPage - 1})" class="page-link" title="Previous Page">
                                <i class="bi bi-chevron-left"></i> Previous
                            </button>
                         </li>`;
            }

            // Page numbers
            const startPage = Math.max(1, currentPage - 2);
            const endPage = Math.min(totalPages, currentPage + 2);

            if (startPage > 1) {
                html += `<li class="page-item">
                            <button onclick="goToPageWithScroll(1)" class="page-link">1</button>
                         </li>`;
                if (startPage > 2) {
                    html += `<li class="page-item disabled"><span class="page-link">...</span></li>`;
                }
            }

            for (let i = startPage; i <= endPage; i++) {
                if (i === currentPage) {
                    html += `<li class="page-item active"><span class="page-link">${i}</span></li>`;
                } else {
                    html += `<li class="page-item">
                                <button onclick="goToPageWithScroll(${i})" class="page-link">${i}</button>
                             </li>`;
                }
            }

            if (endPage < totalPages) {
                if (endPage < totalPages - 1) {
                    html += `<li class="page-item disabled"><span class="page-link">...</span></li>`;
                }
                html += `<li class="page-item">
                            <button onclick="goToPageWithScroll(${totalPages})" class="page-link">${totalPages}</button>
                         </li>`;
            }

            // Next Button
            if (currentPage < totalPages) {
                html += `<li class="page-item">
                            <button onclick="goToPageWithScroll(${currentPage + 1})" class="page-link" title="Next Page">
                                Next <i class="bi bi-chevron-right"></i>
                            </button>
                         </li>`;
            }

            // Last Page Button
            if (currentPage < totalPages - 1) {
                html += `<li class="page-item">
                            <button onclick="goToPageWithScroll(${totalPages})" class="page-link" title="Last Page">
                                Last <i class="bi bi-chevron-double-right"></i>
                            </button>
                         </li>`;
            }

            paginationNav.innerHTML = html;
        }

        // Page size change handler
        async function changePageSize() {
            const pageSize = document.getElementById('pageSizeSelect').value;
            const params = new URLSearchParams(window.location.search);
            params.set('pageSize', pageSize);
            params.set('pageNo', '1'); // Reset to first page
            
            window.location.href = window.location.pathname + '?' + params.toString();
        }

        // Loading indicator functions
        function showLoadingIndicator() {
            const paginationWrapper = document.querySelector('.pagination-wrapper');
            if (paginationWrapper) {
                paginationWrapper.style.opacity = '0.6';
                paginationWrapper.style.pointerEvents = 'none';
            }
            
            // Add loading spinner
            const spinner = document.createElement('div');
            spinner.id = 'pagination-loading';
            spinner.innerHTML = `
                <div style="display: flex; justify-content: center; align-items: center; padding: 20px;">
                    <div style="width: 30px; height: 30px; border: 3px solid #f3f3f3; border-top: 3px solid #667eea; border-radius: 50%; animation: spin 1s linear infinite;"></div>
                    <span style="margin-left: 10px; color: #667eea;">Loading...</span>
                </div>
              
            `;
            
            const articlesSection = document.querySelector('.articles-list');
            if (articlesSection) {
                articlesSection.appendChild(spinner);
            }
        }

        function hideLoadingIndicator() {
            const paginationWrapper = document.querySelector('.pagination-wrapper');
            if (paginationWrapper) {
                paginationWrapper.style.opacity = '1';
                paginationWrapper.style.pointerEvents = 'auto';
            }
            
            const spinner = document.getElementById('pagination-loading');
            if (spinner) {
                spinner.remove();
            }
        }

        // Error display function
        function showError(message) {
            const errorAlert = document.createElement('div');
            errorAlert.className = 'alert error-alert';
            errorAlert.innerHTML = `
                ⚠ ${message}
                <button type="button" class="alert-close" onclick="this.parentElement.remove()">×</button>
            `;
            
            const mainContent = document.querySelector('.main-content');
            if (mainContent) {
                mainContent.insertBefore(errorAlert, mainContent.firstChild);
                setTimeout(() => errorAlert.remove(), 5000);
            }
        }

        // Filter toggle function (existing)
        function toggleFilters() {
            const filterFields = document.getElementById('filterFields');
            const toggleBtn = document.querySelector('.btn-toggle-filters i');

            if (filterFields.style.display === 'none' || !filterFields.classList.contains('show')) {
                filterFields.style.display = 'block';
                filterFields.classList.add('show');
                toggleBtn.className = 'bi bi-chevron-up';
            } else {
                filterFields.style.display = 'none';
                filterFields.classList.remove('show');
                toggleBtn.className = 'bi bi-chevron-down';
            }
        }

        // Initialize on page load
        document.addEventListener('DOMContentLoaded', function () {
            // Initialize filters as hidden
            const filterFields = document.getElementById('filterFields');
            const toggleBtn = document.querySelector('.btn-toggle-filters i');

            if (filterFields && toggleBtn) {
                filterFields.style.display = 'none';
                filterFields.classList.remove('show');
                toggleBtn.className = 'bi bi-chevron-down';
            }
        });
    </script>
}