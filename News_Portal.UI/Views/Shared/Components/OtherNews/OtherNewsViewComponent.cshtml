@model List<HomePageNewsToShowDTO>
@{
    var lang = Context.Request.Cookies["Language"];
    bool isBangla = (lang == Languages.Bangla.ToString()) ? true : false;
}

<div class="two-col-featured">
    <div class="tc-main">
        @if (Model != null && Model.Count > 0)
        {
            @await Html.PartialAsync("~/Views/Shared/PartialViews/LargeNewsCard.cshtml", Model[0])
        }
        else
        {
            <div class="placeholder-content">
                <span>@(isBangla ? "কোনো প্রধান সংবাদ উপলব্ধ নেই।" : "No featured news available")</span>
            </div>
        }
    </div>

    <div class="tc-side tc-side-top">
        @if (Model != null && Model.Count > 1)
        {
            @await Html.PartialAsync("~/Views/Shared/PartialViews/HomePageItemCard2.cshtml", Model[1])
        }
        else
        {
            <div class="placeholder-content">
                <span>@(isBangla ? "কোনো সংবাদ উপলব্ধ নেই।" : "No news available")</span>
            </div>
        }
    </div>

    <div class="tc-side tc-side-middle">
        @if (Model != null && Model.Count > 2)
        {
            @await Html.PartialAsync("~/Views/Shared/PartialViews/HomePageItemCard2.cshtml", Model[2])
        }
        else
        {
            <div class="placeholder-content">
                <span>@(isBangla ? "কোনো সংবাদ উপলব্ধ নেই।" : "No news available")</span>
            </div>
        }
    </div>

    <div class="tc-side tc-side-bottom">
        @if (Model != null && Model.Count > 3)
        {
            @await Html.PartialAsync("~/Views/Shared/PartialViews/HomePageItemCard2.cshtml", Model[3])
        }
        else
        {
            <div class="placeholder-content">
                <span>@(isBangla ? "কোনো সংবাদ উপলব্ধ নেই।" : "No news available")</span>
            </div>
        }
    </div>
</div>
