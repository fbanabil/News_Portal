@model ApplicationUser

<div class="d-flex align-items-center">
    @if (Model != null)
    {
        <a asp-area="Identity" asp-controller="Profile" asp-action="ProfileDetails" class="d-flex align-items-center text-decoration-none" style="color: inherit;">
            <img src="@(Model.PersonImageUrl ?? ViewBag.ProfileImageUrl)"
                 alt="@(Model.PersonName ?? "User Profile")" 
                 class="rounded-circle me-2" 
                 style="width: 32px; height: 32px; object-fit: cover; cursor: pointer;" 
                 onerror="this.src='@ViewBag.ProfileImageUrl'" />
            <span class="text-truncate" style="max-width: 120px; cursor: pointer;" title="@(Model.PersonName ?? Model.Email)">
                @(Model.PersonName ?? Model.Email ?? "Anonymous User")
            </span>
        </a>
    }
    else
    {
        <div class="d-flex align-items-center">
            <img src="@ViewBag.ProfileImageUrl"
                 alt="User Profile" 
                 class="rounded-circle me-2" 
                 style="width: 32px; height: 32px; object-fit: cover;" />
            <span class="text-truncate" style="max-width: 120px;">
                Anonymous User
            </span>
        </div>
    }
</div>