@model List<HomePageNewsToShowDTO>  
@{
    var lang = Context.Request.Cookies["Language"];
    bool isBangla = (lang == Languages.Bangla.ToString()) ? true : false;
}
<div class="top-news-header d-flex align-items-center justify-content-between mb-2">
    <div class="d-flex align-items-center gap-2">
        <span class="heading-icon" aria-hidden="true">📰</span>
        <h2 class="h5 mb-0">@(isBangla?"শীর্ষ খবর":"Top News")</h2>
    </div>
</div>
<div class="heading-accent" role="presentation"></div>

<div class="row g-2 g-md-3 mt-2">
    @if (Model is { Count: > 0 })
    {
        foreach (var news in Model)
        {
            <div class="col-12">
                @await Html.PartialAsync("~/Views/Shared/PartialViews/TopNewsNewsCard.cshtml", news)
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="alert alert-light border mb-0">@(isBangla ? "এই বিষয়ে এখন কিছু নেই" : "No suggestions available.")</div>
        </div>
    }
</div>

