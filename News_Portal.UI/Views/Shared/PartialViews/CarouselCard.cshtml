@model News_Portal.Core.DTO.News.HomePageNewsToShowDTO
@{
    var lang = Context.Request.Cookies["Language"];
    if (lang == null) lang = Languages.Bangla.ToString();
    bool isBangla = (lang == Languages.Bangla.ToString()) ? true : false;
}
<a asp-controller="Home" asp-action="Details" asp-route-newsId="@Model.NewsId"
   class="news-card-compact text-decoration-none d-block"
   aria-label="Read '@Model.NewsTitle'">

    <div class="position-relative overflow-hidden">
        <div class="ratio">
            <img src="@Model.TitleImageUrl"
                 alt="@Model.NewsTitle"
                 loading="lazy" />
        </div>
        <div class="position-absolute top-0 end-0 m-2">
            <span class="news-badge">@(isBangla? Model.NewsType.GetDisplayName() : Model.NewsType.ToString())</span>
        </div>
    </div>

    <div class="card-body">
        <h6 class="card-title" title="@Model.NewsTitle">
            @Html.Raw(Model.NewsTitle?.RemoveClampBreakingElements())
        </h6>

        <div class="card-meta d-flex justify-content-between align-items-center">
            <span class="card-date">@(isBangla ? (Model.PublishedDate.GetBengaliDate()) : Model.PublishedDate.ToString("MMM dd"))</span>
        </div>

        <p class="card-text">
            @Html.Raw((Model.NewsContent?.RemoveClampBreakingElements() ?? string.Empty))
        </p>

        <div class="card-footer-info d-flex justify-content-between align-items-center">
            <span class="view-count">@(isBangla? Model.TotalViews.ToString("N0").ToBanglaDigits() : Model.TotalViews.ToString("N0"))</span>
            <i class="bi bi-arrow-right read-more-arrow"></i>
        </div>
    </div>
</a>