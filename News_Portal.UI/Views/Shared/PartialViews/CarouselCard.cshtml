@model News_Portal.Core.DTO.News.HomePageNewsToShowDTO
<div class="col-12 col-sm-6 col-lg-3">
    <a asp-controller="Home" asp-action="Details" asp-route-newsId="@Model.NewsId"
       class="card h-100 news-card news-card-compact text-reset text-decoration-none position-relative"
       aria-label="Read '@Model.NewsTitle'">
        <div class="ratio ratio-4x3">
            <img src="@Model.TitleImageUrl"
                 class="object-fit-cover"
                 alt="@Model.NewsTitle"
                 loading="lazy" />
        </div>
        <div class="card-body d-flex flex-column">
            <h6 class="card-title text-truncate mb-1" title="@Model.NewsTitle">@Model.NewsTitle</h6>
            <p class="small text-muted mb-1 d-flex align-items-center gap-2">
                <span>@Model.PublishedDate.ToString("MMM dd, yyyy")</span>
                <span class="badge badge-flat">@Model.NewsType</span>
            </p>
            <p class="card-text xsmall flex-grow-1 mb-1">
                @((Model.NewsContent ?? string.Empty).Length > 100
                    ? Model.NewsContent!.Substring(0,100) + "…"
                    : Model.NewsContent)
            </p>
            <span class="xsmall text-muted">@Model.TotalViews.ToString("N0") views</span>
            <span class="stretched-link"></span>
        </div>
    </a>
</div>