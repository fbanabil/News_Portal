@model News_Portal.Core.DTO.News.HomePageNewsToShowDTO
<div class="col-10 col-sm-6 col-lg-4">
    <a asp-controller="Home" asp-action="Details" asp-route-newsId="@Model.NewsId"
       class="card h-100 shadow-sm news-card text-reset text-decoration-none position-relative"
       aria-label="Read '@Model.NewsTitle'">
        <div class="ratio ratio-16x9">
            <img src="@Model.TitleImageUrl"
                 class="object-fit-cover"
                 alt="@Model.NewsTitle"
                 loading="lazy" />
        </div>
        <div class="card-body d-flex flex-column">
            <h6 class="card-title text-truncate mb-1" title="@Model.NewsTitle">@Model.NewsTitle</h6>
            <p class="small text-muted mb-2">
                <span class="me-2">@Model.PublishedDate.ToString("MMM dd, yyyy")</span>
                <span class="badge bg-secondary">@Model.NewsType</span>
            </p>
            <p class="card-text small flex-grow-1 mb-2">
                @((Model.NewsContent ?? string.Empty).Length > 140
                    ? Model.NewsContent!.Substring(0,140) + "…"
                    : Model.NewsContent)
            </p>
            <span class="small text-muted">@Model.TotalViews.ToString("N0") views</span>
            <span class="stretched-link"></span>
        </div>
    </a>
</div>