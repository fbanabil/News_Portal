@using News_Portal.Core.DTO.News
@model HomePageNewsToShowDTO

@{
    var content = Model.NewsContent ?? string.Empty;
    var snippet = content.Length > 120 ? content.Substring(0, 120) + "..." : content;
    var dateText = Model.PublishedDate.ToString("MMM dd, yyyy");
    var timeAgo = GetTimeAgo(Model.PublishedDate);
    var category = Model.NewsType.ToString().ToLower();
    var readTime = EstimateReadTime(content);
}

@functions {
    private string GetTimeAgo(DateTime publishedDate)
    {
        var timeSpan = DateTime.Now - publishedDate;
        if (timeSpan.TotalDays > 7) return publishedDate.ToString("MMM dd");
        if (timeSpan.TotalDays >= 1) return $"{(int)timeSpan.TotalDays}d ago";
        if (timeSpan.TotalHours >= 1) return $"{(int)timeSpan.TotalHours}h ago";
        if (timeSpan.TotalMinutes >= 1) return $"{(int)timeSpan.TotalMinutes}m ago";
        return "Just now";
    }
    
    private string EstimateReadTime(string content)
    {
        var wordCount = content?.Split(' ').Length ?? 0;
        var minutes = Math.Max(1, wordCount / 200);
        return $"{minutes} min read";
    }
}

<article class="modern-news-card" data-category="@category">
    <div class="card-media">
        @if (!string.IsNullOrWhiteSpace(Model.TitleImageUrl))
        {
            <img src="@Model.TitleImageUrl" 
                 alt="@Model.NewsTitle" 
                 class="card-image"
                 loading="lazy" />
            <div class="image-overlay">
                <span class="category-badge badge-@category">
                    @GetCategoryIcon(category) @Model.NewsType.ToString()
                </span>
            </div>
        }
        else
        {
            <div class="card-placeholder">
                <div class="placeholder-content">
                    <span class="placeholder-icon">@GetCategoryIcon(category)</span>
                    <span class="placeholder-text">@Model.NewsType.ToString()</span>
                </div>
            </div>
        }
        
        @if (Model.TotalViews > 1000)
        {
            <div class="trending-badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M16 6l2.29 2.29-4.88 4.88-4-4L2 16.59 3.41 18l6-6 4 4 6.3-6.29L22 12V6h-6z"/>
                </svg>
                Trending
            </div>
        }
    </div>

    <div class="card-content">
        <header class="card-header">
            <div class="meta-info">
                <time class="publish-time" datetime="@Model.PublishedDate.ToString("yyyy-MM-dd")">
                    @timeAgo
                </time>
                <span class="read-time">@readTime</span>
            </div>
            
            @if (Model.Author != null)
            {
                <div class="author-info">
                    <span class="author-name">@Model.Author.UserName</span>
                </div>
            }
        </header>

        <h3 class="card-title">
            <a href="@Url.Action("Details", "News", new { id = Model.NewsId })" 
               class="title-link"
               aria-label="Read full article: @Model.NewsTitle">
                @Model.NewsTitle
            </a>
        </h3>

        @if (!string.IsNullOrWhiteSpace(snippet))
        {
            <p class="card-excerpt">
                @snippet
            </p>
        }

        <footer class="card-footer">
            <div class="engagement-stats">
                @if (Model.TotalViews > 0)
                {
                    <span class="stat-item views">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/>
                        </svg>
                        @FormatNumber(Model.TotalViews)
                    </span>
                }
                
                <span class="stat-item comments">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M20 2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h4l4 4 4-4h4c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/>
                    </svg>
                    @(new Random().Next(0, 25))
                </span>
                
                <span class="stat-item likes">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                    </svg>
                    @(new Random().Next(5, 100))
                </span>
            </div>
            
            <button class="bookmark-btn" type="button" aria-label="Bookmark this article">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M17 3H7c-1.1 0-2 .9-2 2v16l7-3 7 3V5c0-1.1-.9-2-2-2z"/>
                </svg>
            </button>
        </footer>
    </div>
</article>

@functions {
    private string GetCategoryIcon(string category)
    {
        return category.ToLower() switch
        {
            "politics" => "🏛️",
            "sports" => "⚽",
            "technology" => "💻",
            "entertainment" => "🎬",
            "business" => "💼",
            "health" => "🏥",
            "science" => "🔬",
            "world" => "🌍",
            _ => "📰"
        };
    }
    
    private string FormatNumber(int number)
    {
        if (number >= 1000000) return $"{number / 1000000.0:F1}M";
        if (number >= 1000) return $"{number / 1000.0:F1}K";
        return number.ToString();
    }
}
