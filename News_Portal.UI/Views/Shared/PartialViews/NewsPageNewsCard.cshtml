@model News_Portal.Core.DTO.News.HomePageNewsToShowDTO
@{
    var lang = Context.Request.Cookies["Language"];
    if (lang == null) lang = Languages.Bangla.ToString();
    bool isBangla = (lang == Languages.Bangla.ToString()) ? true : false;
}

<div class="col-10 col-sm-6 col-lg-4">
    <a asp-controller="Home" asp-action="Details" asp-route-newsId="@Model.NewsId"
       class="card h-100 shadow-sm news-card text-reset text-decoration-none d-flex flex-column"
       aria-label="View details for @Model.NewsTitle">
        <div class="ratio ratio-16x9">
            <img src="@Model.TitleImageUrl"
                 class="object-fit-cover"
                 alt="@Model.NewsTitle"
                 loading="lazy" />
        </div>
        <div class="card-body d-flex flex-column">
            <h6 class="card-title text-truncate mb-1" title="@Model.NewsTitle">@Html.Raw(Model.NewsTitle?.RemoveClampBreakingElements().StripHtmlTags())</h6>
            <p class="small text-muted mb-2">
                <span class="me-2">@(isBangla? Model.PublishedDate.GetBengaliDate() : Model.PublishedDate.ToString("MMM dd, yyyy"))</span>
            </p>
            <p class="card-text small flex-grow-1 mb-2">
                @Html.Raw((Model.NewsContent?.RemoveClampBreakingElements().StripHtmlTags() ?? string.Empty))
            </p>
            <span class="small text-muted">
                @(isBangla ? Model.TotalViews.ToString().ToBanglaDigits() + " ভিউ" : Model.TotalViews.ToString("N0")+  " views")</span>
            <span class="stretched-link"></span>
        </div>
    </a>
</div>

