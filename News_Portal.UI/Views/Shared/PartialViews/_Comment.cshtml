@model News_Portal.Core.DTO.Comment.CommentToShowDTO  
@{
    var lang = Context.Request.Cookies["Language"];
    if (lang == null) lang = Languages.Bangla.ToString();
    bool isBangla = (lang == Languages.Bangla.ToString()) ? true : false;
}
@{
    var commenter = Model.UserName ?? "Anonymous";
}

<div class="list-group-item list-group-item-action py-3">
    <div class="d-flex justify-content-between align-items-start mb-2">
        <div class="d-flex flex-column">
            <strong class="small">@commenter</strong>
            <span class="text-muted small">
                @(isBangla ? Model.CommentDate.ConvertFrmonEnglishToBangla() : Model.CommentDate.ToLocalTime().ToString("MMM dd, yyyy HH:mm"))
            </span>
        </div>
        <span class="badge text-bg-light text-muted small">
            #@commenter.Substring(0, Math.Min(commenter.Length, 10))
        </span>
    </div>
    <p class="mb-0 small">@Model.CommentText</p>
</div>
