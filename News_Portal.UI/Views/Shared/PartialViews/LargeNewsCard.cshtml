@using News_Portal.Core.DTO.News
@model HomePageNewsToShowDTO
@{
    var lang = Context.Request.Cookies["Language"];
    if (lang == null) lang = Languages.Bangla.ToString();
    bool isBangla = (lang == Languages.Bangla.ToString()) ? true : false;
}
@{
    var content = Model.NewsContent ?? string.Empty;
    var snippet = content;
    var dateText = isBangla ? Model.PublishedDate.GetBengaliDate() : Model.PublishedDate.ToString("MMM dd, yyyy");
    var category = isBangla ? Model.NewsType.GetDisplayName() : Model.NewsType.ToString();
}
<a asp-action="Details" asp-controller="Home" asp-route-newsId="@Model.NewsId" class="news-card-compact text-decoration-none d-block">

<div class="hero-news-card card h-100 border-0">
    <div class="hero-image-wrapper">
        @if (!string.IsNullOrWhiteSpace(Model.TitleImageUrl))
        {
            <img src="@Model.TitleImageUrl"
                 alt="@Model.NewsTitle"
                 class="hero-image img-fluid"
                 loading="lazy"/>
        }
        else
        {

        }

        <div class="hero-image-overlay">
            @* <span class="news-badge">@category</span> *@
            <span class="hero-date">@dateText</span>
        </div>
    </div>

    <div class="hero-body card-body p-3 p-md-3">
        <h3 class="hero-title mb-2">
                @Html.Raw(Model.NewsTitle?.RemoveClampBreakingElements())
        </h3>

        @if (!string.IsNullOrWhiteSpace(snippet))
        {
            <p class="hero-snippet mb-2">
                @Html.Raw(snippet?.RemoveClampBreakingElements())
            </p>
        }

        <div class="hero-meta">
            @if (Model.Author != null)
            {
                <span class="hero-author">
                    <i class="bi bi-person-circle me-1"></i>
                    @Model.Author.UserName
                </span>
            }

            <span class="hero-views">
                <i class="bi bi-eye me-1"></i>
                    @(isBangla? @Model.TotalViews.ToString().ToBanglaDigits() + " ভিউ": Model.TotalViews.ToString("N0") + " views")
                
            </span>
        </div>

      

    </div>
</div>
</a>