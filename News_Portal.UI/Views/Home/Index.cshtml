@{
    ViewBag.Title = "General";
    ViewBag.NewsType = NewsType.General;
}

@* ~\Shared\Components\Carousel\CarouselViewComponent.cshtml *@

@* Top news in carousel *@

<div class="news-heading" aria-label="Top News carousel heading">
    <h2 class="carousel-heading">
        <span class="heading-icon" aria-hidden="true">📰</span>
        Top News
    </h2>
    <div class="heading-accent" role="presentation"></div>
</div>

@await Component.InvokeAsync("Carousel") 




<div class="news-heading d-flex align-items-center justify-content-between" aria-label="Politics section heading">
    <div class="d-flex align-items-center gap-2">
        <h2 class="carousel-heading mb-0">
            <span class="heading-icon" aria-hidden="true">📰</span>
            Politics
        </h2>
    </div>
    <a asp-area=""
       asp-controller="Home"
       asp-action="GetNews"
       asp-route-newsType=@NewsType.Politics
       asp-route-pageNo="1"
       asp-route-pageSize="18"
       class="btn btn-sm btn-outline-primary see-all-btn">
        See all
    </a>
</div>
<div class="heading-accent mb-2" role="presentation"></div>

@await Component.InvokeAsync("OtherNews", NewsType.Politics)






