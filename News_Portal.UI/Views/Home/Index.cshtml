@{
    var lang = Context.Request.Cookies["Language"];
    bool isBangla = (lang == Languages.Bangla.ToString()) ? true : false;
    ViewBag.Title = isBangla ? "সাধারণ" : "General";
}


@if(isBangla)
{
   <header class="newspaper-header">
        <h1 class="newspaper-title">ডেইলি নিউজ পোর্টাল</h1>
        <div class="newspaper-date">@DateTime.Now.GetBengaliDate()</div>
        <div class="newspaper-line"></div>
   </header>
}
else
{
    <header class="newspaper-header">
        <h1 class="newspaper-title">Daily News Portal</h1>
        <div class="newspaper-date">@DateTime.Now.ToString("MMMM dd, yyyy")</div>
        <div class="newspaper-line"></div>
    </header>
}



@if (TempData["Message"] != null)
{
    <div class="alert success-alert">
        ✓ @TempData["Message"]
        <button type="button" class="alert-close" onclick="this.parentElement.style.display='none'">×</button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert error-alert">
        ⚠ @TempData["Error"]
        <button type="button" class="alert-close" onclick="this.parentElement.style.display='none'">×</button>
    </div>
}



<main class="newspaper-main">
    <section class="top-banner">
        <h2 class="section-title">@(isBangla ? "সর্বাধিক জনপ্রিয় সংবাদ" : "Most Favourite News")</h2>
        @await Component.InvokeAsync("Carousel")
    </section>

    <div class="newspaper-content">
        <div class="main-column">
            <article class="news-section politics">
                <h3 class="category-title">@(isBangla ? "রাজনীতি" : "Politics") <a href="@Url.Action("GetNews", "Home", new { newsType = NewsType.Politics, pageNo = 1, pageSize = 18 })" class="see-more">@(isBangla ? "সব দেখুন" : "See all") →</a></h3>
                @await Component.InvokeAsync("OtherNews", NewsType.Politics)
            </article>

            <div class="two-column-section">
                <article class="news-section technology">
                    <h3 class="category-title">@(isBangla?"প্রযুক্তি":"Technology") <a href="@Url.Action("GetNews", "Home", new { newsType = NewsType.Technology, pageNo = 1, pageSize = 18 })" class="see-more">@(isBangla ? "সব দেখুন" : "See all") →</a></h3>
                    @await Component.InvokeAsync("OtherNews", NewsType.Technology)
                </article>

                <article class="news-section sports">
                    <h3 class="category-title">@(isBangla ? "খেলাধুলা" : "Sports") <a href="@Url.Action("GetNews", "Home", new { newsType = NewsType.Sports, pageNo = 1, pageSize = 18 })" class="see-more">@(isBangla ? "সব দেখুন" : "See all") →</a></h3>
                    @await Component.InvokeAsync("OtherNews", NewsType.Sports)
                </article>
            </div>


            <div class="two-column-section">
                <article class="news-section business">
                    <h3 class="category-title">@(isBangla ? "ব্যবসা-বাণিজ্য" : "Business") <a href="@Url.Action("GetNews", "Home", new { newsType = NewsType.Business, pageNo = 1, pageSize = 18 })" class="see-more">@(isBangla ? "সব দেখুন" : "See all") →</a></h3>
                    @await Component.InvokeAsync("OtherNews", NewsType.Business)
                </article>

                <article class="news-section entertainment">
                    <h3 class="category-title">@(isBangla ? "বিনোদন" : "Entertainment") <a href="@Url.Action("GetNews", "Home", new { newsType = NewsType.Entertainment, pageNo = 1, pageSize = 18 })" class="see-more">@(isBangla ? "সব দেখুন" : "See all") →</a></h3>
                    @await Component.InvokeAsync("OtherNews", NewsType.Entertainment)
                </article>
            </div>

            <div class="two-column-section">
                <article class="news-section science">
                    <h3 class="category-title">@(isBangla ? "বিজ্ঞান" : "Science") <a href="@Url.Action("GetNews", "Home", new { newsType = NewsType.Science, pageNo = 1, pageSize = 18 })" class="see-more">@(isBangla ? "সব দেখুন" : "See all") →</a></h3>
                    @await Component.InvokeAsync("OtherNews", NewsType.Science)
                </article>

                <article class="news-section health">
                    <h3 class="category-title">@(isBangla ? "স্বাস্থ্য" : "Health") <a href="@Url.Action("GetNews", "Home", new { newsType = NewsType.Health, pageNo = 1, pageSize = 18 })" class="see-more">@(isBangla ? "সব দেখুন" : "See all") →</a></h3>
                    @await Component.InvokeAsync("OtherNews", NewsType.Health)
                </article>
            </div>

            <article class="news-section world">
                <h3 class="category-title">@(isBangla ? "বিশ্ব সংবাদ" : "World News") <a href="@Url.Action("GetNews", "Home", new { newsType = NewsType.World, pageNo = 1, pageSize = 18 })" class="see-more">@(isBangla ? "সব দেখুন" : "See all") →</a></h3>
                @await Component.InvokeAsync("OtherNews", NewsType.World)
            </article>
        </div>

        <aside class="sidebar">
            <div class="sidebar-section">
                <h4 class="sidebar-title">@(isBangla ? "📌 পিন করা" : "📌 Pinned")</h4>
                @await Component.InvokeAsync("Top", new { type = TopOfXType.Pinned, cnt = 1 })
            </div>

            <div class="sidebar-section">
                <h4 class="sidebar-title">@(isBangla ? "📊 সাপ্তাহিক শীর্ষ" : "📊 Weekly Top")</h4>
                @await Component.InvokeAsync("Top", new { type = TopOfXType.AllTime, cnt = 6 })
            </div>

            <div class="sidebar-section">
                <h4 class="sidebar-title">@(isBangla ? "📅 মাসিক শীর্ষ" : "📅 Monthly Top")</h4>
                @await Component.InvokeAsync("Top", new { type = TopOfXType.AllTime, cnt = 6 })
            </div>
            <div class="sidebar-section">
                <h4 class="sidebar-title">@(isBangla ? "📅 সর্বকালের শীর্ষ" : "📅 All Time Top")</h4>
                @await Component.InvokeAsync("Top", new { type = TopOfXType.AllTime, cnt = 6 })
            </div>
        </aside>
    </div>
</main>

@section Scripts {
    <script>
        setTimeout(() => {
            document.querySelectorAll('.alert').forEach(alert => alert.style.display = 'none');
        }, 5000);
    </script>
}
