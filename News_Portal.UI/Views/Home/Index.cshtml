@{
    ViewBag.Title = "General";
    ViewBag.NewsType = NewsType.General;
}

<div class="home-container">
    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>
            @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

            <div class="news-sections-wrapper">
        <!-- Top News Carousel Section -->
        <div class="news-section top-news-section">
            <div class="news-heading" aria-label="Top News carousel heading">
                <h2 class="carousel-heading">
                    <span class="heading-icon" aria-hidden="true">📰</span>
                    Top News
                    <span class="badge">Featured</span>
                </h2>
                <div class="heading-accent" role="presentation"></div>
            </div>
            
            @await Component.InvokeAsync("Carousel")
        </div>

        <!-- Politics Section -->
        <div class="news-section">
            <div class="news-heading d-flex align-items-center justify-content-between category-politics" aria-label="Politics section heading">
                <div class="d-flex align-items-center gap-2">
                    <h2 class="carousel-heading mb-0">
                        <span class="heading-icon" aria-hidden="true">🏛️</span>
                        Politics
                    </h2>
                </div>
                <a asp-area=""
                   asp-controller="Home"
                   asp-action="GetNews"
                   asp-route-newsType=@NewsType.Politics
                   asp-route-pageNo="1"
                   asp-route-pageSize="18"
                   class="see-all-btn">
                    See all
                    <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
            <div class="heading-accent mb-3" role="presentation"></div>
            
            @await Component.InvokeAsync("OtherNews", NewsType.Politics)
