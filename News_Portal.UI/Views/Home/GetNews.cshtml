@model List<News_Portal.Core.DTO.News.HomePageNewsToShowDTO>
@{
    var lang = Context.Request.Cookies["Language"];
    if (lang == null) lang = Languages.Bangla.ToString();
    bool isBangla = (lang == Languages.Bangla.ToString()) ? true : false;
}

@{
    ViewBag.Title = ViewBag.NewsType?.ToString() ?? "News";
    NewsType title = Model[0].NewsType;
    int pageNo = ViewBag.PageNo is int p ? p : 1;
    int pageSize = ViewBag.PageSize is int ps ? ps : 12;
    int pageCount = ViewBag.PageCount is int pc ? pc : 1;
    var categoryIcon = ViewBag.NewsType?.ToString().ToLowerInvariant() switch
    {
        "politics" => "bi bi-bank",
        "sports" => "bi bi-trophy",
        "technology" => "bi bi-cpu",
        "business" => "bi bi-briefcase",
        "entertainment" => "bi bi-film",
        "science" => "bi bi-journal-text",
        "health" => "bi bi-heart-pulse",
        "world" => "bi bi-globe",
        _ => "bi bi-newspaper"
    };
}


@await Html.PartialAsync("PartialViews/MessagePartial")


<div class="simple-category-header">
    <div class="container-fluid">
        <div class="d-flex flex-column flex-md-row align-items-start align-items-md-center justify-content-between gap-3">
            <div class="d-flex align-items-center">
                <i class="@categoryIcon me-3"></i>
                <div>
                    <h2 class="category-title mb-1">@title</h2>
                    <small class="text-muted"> @(isBangla ? "পেজ " + @pageCount.ToString().ToBanglaDigits() + " এর ভেতরে " + @pageNo.ToString().ToBanglaDigits()  : "Page " + @pageNo.ToString() + " of " + @pageCount.ToString()) </small>
                </div>
            </div>
            <div class="category-stats">
                <span class="badge bg-light text-dark">
                    @{
                        int pa = ((pageNo - 1) * pageSize + 1);
                        int qa = (Math.Min(pageNo * pageSize, (Model?.Count ?? 0) + (pageNo - 1) * pageSize));
                    }
                                        
                    @if(isBangla)
                    {
                        @pa.ToString().ToBanglaDigits() @:-  @qa.ToString().ToBanglaDigits() 
                        @:সংবাদ
                    }
                    else
                    {
                          @pa.ToString() @:-  @qa.ToString() 
                          @:articles
                    }
                    
                </span>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid">
    <div class="row news-grid-container">
        <div class="col-12 col-lg-8 col-xl-9 main-content">
            @if (Model == null || Model.Count == 0)
            {
                <div class="no-news-message">
                    <div class="no-news-icon">
                        <i class="bi bi-newspaper"></i>
                    </div>
                    <h4 class="text-muted">@(isBangla?"কোন "+ title.ToString() +" সংবাদ নেই":"No "+ title.ToString() +" News Available") </h4>
                    <p class="text-muted">@(isBangla?"Check back later for the latest updates in "+ @title.GetDisplayName().ToLower():"Check back later for the latest updates in "+@title.ToString().ToLower())</p>
                </div>
            }
            else
            {
                <div class="row news-grid g-2 g-sm-3 g-md-4">
                    @foreach (var news in Model)
                    {
                        var author = news.Author;
                        <div class="col-6 col-sm-6 col-lg-6 col-xl-4">
                            <a asp-controller="Home" asp-action="Details" asp-route-newsId="@news.NewsId"
                               class="news-card-enhanced text-reset text-decoration-none d-flex flex-column h-100">
                                <div class="news-card-image">
                                    <img src="@(string.IsNullOrWhiteSpace(news.TitleImageUrl) ? "https://via.placeholder.com/400x200?text=News" : news.TitleImageUrl)"
                                         alt="@news.NewsTitle"
                                         loading="lazy" />
                                </div>
                                <div class="news-card-body flex-grow-1 d-flex flex-column">
                                    <h5 class="news-card-title" title="@news.NewsTitle">@Html.Raw(news.NewsTitle?.RemoveClampBreakingElements())</h5>
                                    <div class="news-card-meta">
                                        <span><i class="bi bi-calendar3 me-1"></i>@(isBangla? news.PublishedDate.GetBengaliDate() : news.PublishedDate.ToString("MMM dd, yyyy"))</span>
                                        <span><i class="bi bi-person me-1"></i>@author?.PersonName</span>
                                    </div>
                                    <p class="news-card-content flex-grow-1">
                                        @Html.Raw((news.NewsContent?.RemoveClampBreakingElements() ?? string.Empty))
                                    </p>
                                    <div class="news-card-footer mt-auto">
                                        <div class="view-count">
                                            <i class="bi bi-eye"></i>
                                            @(isBangla? news.TotalViews.ToString("N0").ToBanglaDigits() : news.TotalViews.ToString("N0"))
                                        </div>
                                        <small class="text-primary">@(isBangla?"আরো পড়ি":"Read more") →</small>
                                    </div>
                                </div>
                            </a>
                        </div>
                    }
                </div>
            }

            @if (pageCount > 1)
            {
                <nav class="d-flex justify-content-center mt-4" aria-label="Pagination">
                    <ul class="pagination pagination-enhanced mb-0 flex-wrap">
                        @{
                            bool hasPrev = pageNo > 1;
                            bool hasNext = pageNo < pageCount;
                            var routeType = (NewsType)ViewBag.NewsType;
                        }

                        <li class="page-item @(hasPrev ? "" : "disabled")">
                            <a class="page-link"
                               asp-controller="Home"
                               asp-action="GetNews"
                               asp-route-newsType="@routeType"
                               asp-route-pageNo="@(pageNo - 1)"
                               asp-route-pageSize="@pageSize">
                                <i class="bi bi-chevron-left"></i> <span class="d-none d-sm-inline">@(isBangla?"পূর্ববর্তী":"Previous")</span>
                            </a>
                        </li>

                        @for (int i = Math.Max(1, pageNo - 2); i <= Math.Min(pageCount, pageNo + 2); i++)
                        {
                            <li class="page-item @(i == pageNo ? "active" : "")">
                                <a class="page-link"
                                   asp-controller="Home"
                                   asp-action="GetNews"
                                   asp-route-newsType="@routeType"
                                   asp-route-pageNo="@i"
                                   asp-route-pageSize="@pageSize">@(isBangla?i.ToString().ToBanglaDigits():i)</a>
                            </li>
                        }

                        <li class="page-item @(hasNext ? "" : "disabled")">
                            <a class="page-link"
                               asp-controller="Home"
                               asp-action="GetNews"
                               asp-route-newsType="@routeType"
                               asp-route-pageNo="@(pageNo + 1)"
                               asp-route-pageSize="@pageSize">
                                <span class="d-none d-sm-inline">@(isBangla?"পরবর্তী":"Next")</span> <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            }
        </div>

        <aside class="col-12 col-lg-4 col-xl-3 sidebar">
            <div class="sidebar-section">
                <h4 class="sidebar-title">
                    <i class="bi bi-pin-angle-fill text-primary"></i>
                    @(isBangla?"এই মুহূর্তে জনপ্রিয়":"Trending Now") 
                </h4>
                @await Component.InvokeAsync("Top", new { type = TopOfXType.AllTime, cnt = 2 })
            </div>

            <div class="sidebar-section">
                <h4 class="sidebar-title">
                    <i class="bi bi-graph-up text-success"></i>
                    @(isBangla?"অনেক জনপ্রিয়":"Most Popular")
                </h4>
                @await Component.InvokeAsync("Top", new { type = TopOfXType.AllTime, cnt = 2 })
            </div>

            <div class="sidebar-section">
                <h4 class="sidebar-title">
                    <i class="bi bi-trophy text-warning"></i>
                    @(isBangla?"সর্বকালের প্রিয়":"All Time Favorites")
                </h4>
                @await Component.InvokeAsync("Top", new { type = TopOfXType.AllTime, cnt = 2 })
            </div>

            <div class="sidebar-section">
                <h4 class="sidebar-title">
                    <i class="bi bi-grid text-info"></i>
                    @(isBangla?"বিভাগসমূহ ব্রাউজ করুন ":"Browse Categories")
                </h4>
                <div class="d-flex flex-wrap gap-2">
                    @{
                        var categories = new[]
                        {
                            new { Type = NewsType.Politics, Icon = "bi-bank", Color = "primary" },
                            new { Type = NewsType.Sports, Icon = "bi-trophy", Color = "success" },
                            new { Type = NewsType.Technology, Icon = "bi-cpu", Color = "info" },
                            new { Type = NewsType.Business, Icon = "bi-briefcase", Color = "warning" },
                            new { Type = NewsType.Entertainment, Icon = "bi-film", Color = "danger" },
                            new { Type = NewsType.Science, Icon = "bi-flask", Color = "secondary" },
                            new { Type = NewsType.Health, Icon = "bi-heart-pulse", Color = "success" },
                            new { Type = NewsType.World, Icon = "bi-globe", Color = "dark" }
                        };
                    }

                    @foreach (var category in categories)
                    {
                        <a asp-controller="Home"
                           asp-action="GetNews"
                           asp-route-newsType="@category.Type"
                           asp-route-pageNo="1"
                           asp-route-pageSize="18"
                           class="btn btn-outline-@category.Color btn-sm">
                            <i class="@category.Icon me-1"></i>
                            @(isBangla ? @category.Type.GetDisplayName() : @category.Type)
                        </a>
                    }
                </div>
            </div>
        </aside>
    </div>
</div>

@section Scripts {
    <script>
        setTimeout(() => {
            document.querySelectorAll('.alert-enhanced').forEach(alert => {
                const bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            });
        }, 5000);

        document.querySelectorAll('.pagination a').forEach(link => {
            link.addEventListener('click', () => {
                setTimeout(() => {
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                }, 100);
            });
        });
    </script>
        <partial name="_ValidationScriptsPartial" />

}
