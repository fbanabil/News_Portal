@using News_Portal.Core.DTO.Comment
@model News_Portal.Core.DTO.News.DetailedNewsToShowDTO

@{
    ViewData["Title"] = Model.NewsTitle ?? "News Details";
    var galleryId = $"newsGallery_{Model.NewsId}";
    var authorName = Model.Author?.UserName ?? "Unknown";
    var commentsCount = Model.Comments?.Count ?? 0;
    var contentLines = (Model.NewsContent ?? string.Empty)
        .Split(new[] { "\r\n", "\n" }, StringSplitOptions.RemoveEmptyEntries)
        .Select(l => l.Trim())
        .Where(l => !string.IsNullOrWhiteSpace(l))
        .ToList();
    var currentUrl = $"{Context.Request.Scheme}://{Context.Request.Host}{Context.Request.Path}{Context.Request.QueryString}";
}


@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}







<div class="container-lg my-4">
    <div class="news-hero bg-light rounded-3 border p-3 p-md-4 mb-4">
        <div class="d-flex align-items-center gap-2 mb-2">
            <span class="badge text-bg-primary">@Model.NewsType</span>
            <small class="text-muted">Published @Model.PublishedDate.ToString("MMM dd, yyyy")</small>
            <small class="text-muted ms-auto"><i class="bi bi-eye"></i> @Model.TotalViews.ToString("N0") views</small>
        </div>
        <h1 class="h3 h1-md mb-2">@Model.NewsTitle</h1>
        <div class="d-flex flex-wrap gap-3 text-muted small">
            <span><i class="bi bi-person-circle me-1"></i>@authorName</span>
            <span><i class="bi bi-clock-history me-1"></i>Updated @Model.LastUpdate.ToString("MMM dd, yyyy HH:mm")</span>
            <span><i class="bi bi-chat-dots me-1"></i><span id="comments-count">@commentsCount</span> comments</span>
        </div>
    </div>

    <div class="row g-4">
        <main class="col-12 col-lg-8">
            @if (Model.Images?.Any() == true)
            {
                if (Model.Images!.Count > 1)
                {
                    <div id="@galleryId" class="carousel slide mb-3 rounded overflow-hidden shadow-sm" data-bs-ride="carousel">
                        <div class="carousel-indicators">
                            @for (int i = 0; i < Model.Images.Count; i++)
                            {
                                <button type="button"
                                        data-bs-target="#@galleryId"
                                        data-bs-slide-to="@i"
                                        class="@(i == 0 ? "active" : null)"
                                        aria-current="@(i == 0 ? "true" : null)"
                                        aria-label="Slide @(i + 1)"></button>
                            }
                        </div>
                        <div class="carousel-inner">
                            @{
                                var idx = 0;
                                foreach (var img in Model.Images)
                                {
                                    var active = idx == 0 ? "active" : null;
                                    <div class="carousel-item @active">
                                        <div class="ratio ratio-16x9">
                                            <img src="@img.ImageUrl" class="d-block w-100 object-fit-cover" alt="@Model.NewsTitle image @(idx+1)" loading="lazy" />
                                        </div>
                                    </div>;
                                    idx++;
                                }
                            }
                        </div>
                        <button class="carousel-control-prev" type="button" data-bs-target="#@galleryId" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Previous</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#@galleryId" data-bs-slide="next">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Next</span>
                        </button>
                    </div>
                }
                else
                {
                    var img = Model.Images.First();
                    <div class="mb-3 rounded overflow-hidden shadow-sm">
                        <div class="ratio ratio-16x9">
                            <img src="@img.ImageUrl" class="w-100 object-fit-cover" alt="@Model.NewsTitle" />
                        </div>
                    </div>
                }
            }

            <article class="news-article card border-0 shadow-sm mb-4">
                <div class="card-body p-3 p-md-4">
                    @if (contentLines.Count == 0)
                    {
                        <p class="text-muted">No content available.</p>
                    }
                    else
                    {
                        foreach (var line in contentLines)
                        {
                            <p class="fs-6 lh-base">@line</p>
                        }
                    }
                </div>
            </article>

            <!-- Comments Section -->
            <section id="comments" class="mb-5">
                <div class="d-flex align-items-center mb-3">
                    <h2 class="h5 mb-0">Comments (<span id="comments-count">@commentsCount</span>)</h2>
                    <span class="ms-2 badge rounded-pill text-bg-secondary" id="comments-count-badge">@commentsCount</span>
                </div>

                <div id="comments-container">
                    @if (commentsCount == 0)
                    {
                        <div class="alert alert-light border small mb-4" role="status" id="no-comments-alert">
                            No comments yet. Be the first to contribute.
                        </div>
                    }
                    else
                    {
                        <div class="list-group mb-4" id="comments-list">
                            @foreach (var c in Model.Comments!.OrderByDescending(c => c.CommentDate))
                            {
                                @await Html.PartialAsync("~/Views/Shared/PartialViews/_Comment.cshtml", c)
                            }
                        </div>
                    }
                </div>

                <!-- Comment Form -->
                @{
                    CommentToAddDTO commentToaddDTO = new CommentToAddDTO();
                    commentToaddDTO.NewsId = Model.NewsId;
                }
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <h6 class="card-title mb-3">
                            <i class="bi bi-chat-dots me-2"></i>Add a comment
                        </h6>
                        
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <form asp-controller="Home" asp-action="AddComment" method="post" id="comment-form">
                                @Html.AntiForgeryToken()

                                <input type="hidden" name="NewsId" value="@Model.NewsId" />

                                <div class="mb-3">
                                    <label for="CommentText" class="form-label">Your comment</label>
                                    <textarea name="CommentText"
                                          id="CommentText"
                                          class="form-control"
                                          rows="4"
                                          placeholder="Share your thoughts about this news article..."></textarea>
                                    <span asp-validation-for="@commentToaddDTO.CommentText" class="text-danger small"></span>
                                </div>

                                <div class="d-flex justify-content-between align-items-center">
                                    <small class="text-muted">
                                        <i class="bi bi-info-circle me-1"></i>
                                        Commenting as <strong>@ViewBag.PresentUserName</strong>
                                    </small>
                                    <button type="submit" class="btn btn-primary" id="submit-btn">
                                        <i class="bi bi-send me-1"></i>Post Comment
                                    </button>
                                </div>
                            </form>
                        }
                        else
                        {
                            <div class="alert alert-info mb-0">
                                <i class="bi bi-info-circle me-2"></i>
                                <strong>Sign in required:</strong> You must be 
                                <a asp-area="Identity" asp-controller="Account" asp-action="AuthLogin" class="alert-link">logged in</a> 
                                to post comments.
                            </div>
                        }
                    </div>
                </div>
            </section>

            <div>
                @await Component.InvokeAsync("Suggestion",Model.NewsType)
            </div>

        </main>

        <aside class="col-12 col-lg-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="card-title mb-3">Share</h6>
                    <div class="d-flex flex-wrap gap-2">
                        <a class="btn btn-sm btn-outline-primary"
                           target="_blank"
                           rel="noopener"
                           href="https://twitter.com/intent/tweet?url=@Uri.EscapeDataString(currentUrl)&text=@Uri.EscapeDataString(Model.NewsTitle ?? "News")">
                            <i class="bi bi-twitter-x me-1"></i> X
                        </a>
                        <a class="btn btn-sm btn-outline-primary"
                           target="_blank"
                           rel="noopener"
                           href="https://www.facebook.com/sharer/sharer.php?u=@Uri.EscapeDataString(currentUrl)">
                            <i class="bi bi-facebook me-1"></i> Facebook
                        </a>
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="navigator.clipboard.writeText('@currentUrl')">
                            <i class="bi bi-clipboard me-1"></i> Copy link
                        </button>
                    </div>

                    <div class="d-flex flex-wrap gap-2">
                        @await Component.InvokeAsync("TopNews")
                    </div>
                </div>
            </div>
        </aside>
    </div>
</div>

@section Scripts {
    <script>
        const form = document.getElementById("comment-form");
        const commentsContainer = document.getElementById("comments-container");
        const commentsCount = document.getElementById("comments-count");
        const commentsCountBadge = document.getElementById("comments-count-badge");
        const textarea = document.getElementById("CommentText");
        const submitBtn = document.getElementById("submit-btn");

        form.addEventListener("submit", async function (e) {
            e.preventDefault();

            if (!textarea.value.trim()) {
                return;
            }

            // Show loading state
            const originalText = submitBtn.innerHTML;
            submitBtn.innerHTML = '<i class="bi bi-hourglass-split me-1"></i>Posting...';
            submitBtn.disabled = true;

            const formData = new FormData(form);

            try {
                const response = await fetch(form.action, {
                    method: "POST",
                    body: formData
                });

                if (!response.ok) {
                    console.error("Failed to post comment");
                    return;
                }

                const newCommentHtml = await response.text();

                // Check if we need to create comments list (no comments before)
                let commentsList = document.getElementById("comments-list");
                const noCommentsAlert = document.getElementById("no-comments-alert");
                
                if (noCommentsAlert) {
                    // Remove "no comments" message and create comments list
                    noCommentsAlert.remove();
                    commentsList = document.createElement("div");
                    commentsList.className = "list-group mb-4";
                    commentsList.id = "comments-list";
                    commentsContainer.appendChild(commentsList);
                }

                // Add new comment at the top
                commentsList.insertAdjacentHTML("afterbegin", newCommentHtml);

                // Clear textarea
                textarea.value = "";

                // Update counts
                const current = parseInt(commentsCount.textContent || "0");
                const next = current + 1;
                commentsCount.textContent = next;
                commentsCountBadge.textContent = next;

                // Also update the count in the news hero section
                const heroCommentsCount = document.querySelector('.news-hero .bi-chat-dots').nextSibling;
                if (heroCommentsCount) {
                    heroCommentsCount.textContent = ` ${next} comments`;
                }

            } catch (err) {
                console.error("Error posting comment:", err);
            } finally {
                // Restore button state
                submitBtn.innerHTML = originalText;
                submitBtn.disabled = false;
            }
        });
    </script>

    <partial name="_ValidationScriptsPartial" />
}

