@model News_Portal.Core.DTO.News.DetailedNewsToShowDTO

@{
    ViewData["Title"] = Model.NewsTitle ?? "News Details";
    var galleryId = $"newsGallery_{Model.NewsId}";
    var authorName = Model.Author?.UserName ?? "Unknown";
    var commentsCount = Model.Comments?.Count ?? 0;
    var contentLines = (Model.NewsContent ?? string.Empty)
        .Split(new[] { "\r\n", "\n" }, StringSplitOptions.RemoveEmptyEntries)
        .Select(l => l.Trim())
        .Where(l => !string.IsNullOrWhiteSpace(l))
        .ToList();
    var currentUrl = $"{Context.Request.Scheme}://{Context.Request.Host}{Context.Request.Path}{Context.Request.QueryString}";
}

<div class="container-lg my-4">
    <div class="news-hero bg-light rounded-3 border p-3 p-md-4 mb-4">
        <div class="d-flex align-items-center gap-2 mb-2">
            <span class="badge text-bg-primary">@Model.NewsType</span>
            <small class="text-muted">Published @Model.PublishedDate.ToString("MMM dd, yyyy")</small>
            <small class="text-muted ms-auto"><i class="bi bi-eye"></i> @Model.TotalViews.ToString("N0") views</small>
        </div>
        <h1 class="h3 h1-md mb-2">@Model.NewsTitle</h1>
        <div class="d-flex flex-wrap gap-3 text-muted small">
            <span><i class="bi bi-person-circle me-1"></i>@authorName</span>
            <span><i class="bi bi-clock-history me-1"></i>Updated @Model.LastUpdate.ToString("MMM dd, yyyy HH:mm")</span>
            <span><i class="bi bi-chat-dots me-1"></i>@commentsCount comments</span>
        </div>
    </div>

    <div class="row g-4">
        <main class="col-12 col-lg-8">
            @if (Model.Images?.Any() == true)
            {
                if (Model.Images!.Count > 1)
                {
                    <div id="@galleryId" class="carousel slide mb-3 rounded overflow-hidden shadow-sm" data-bs-ride="carousel">
                        <div class="carousel-indicators">
                            @for (int i = 0; i < Model.Images.Count; i++)
                            {
                                <button type="button"
                                        data-bs-target="#@galleryId"
                                        data-bs-slide-to="@i"
                                        class="@(i == 0 ? "active" : null)"
                                        aria-current="@(i == 0 ? "true" : null)"
                                        aria-label="Slide @(i + 1)"></button>
                            }
                        </div>
                        <div class="carousel-inner">
                            @{
                                var idx = 0;
                                foreach (var img in Model.Images)
                                {
                                    var active = idx == 0 ? "active" : null;
                                    <div class="carousel-item @active">
                                        <div class="ratio ratio-16x9">
                                            <img src="@img.ImageUrl" class="d-block w-100 object-fit-cover" alt="@Model.NewsTitle image @(idx+1)" loading="lazy" />
                                        </div>
                                    </div>;
                                    idx++;
                                }
                            }
                        </div>
                        <button class="carousel-control-prev" type="button" data-bs-target="#@galleryId" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Previous</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#@galleryId" data-bs-slide="next">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Next</span>
                        </button>
                    </div>
                }
                else
                {
                    var img = Model.Images.First();
                    <div class="mb-3 rounded overflow-hidden shadow-sm">
                        <div class="ratio ratio-16x9">
                            <img src="@img.ImageUrl" class="w-100 object-fit-cover" alt="@Model.NewsTitle" />
                        </div>
                    </div>
                }
            }

            <article class="news-article card border-0 shadow-sm mb-4">
                <div class="card-body p-3 p-md-4">
                    @if (contentLines.Count == 0)
                    {
                        <p class="text-muted">No content available.</p>
                    }
                    else
                    {
                        foreach (var line in contentLines)
                        {
                            <p class="fs-6 lh-base">@line</p>
                        }
                    }
                </div>
            </article>

            <!-- Comments Section -->
            <section id="comments" class="mb-5">
                <div class="d-flex align-items-center mb-3">
                    <h2 class="h5 mb-0">Comments (@commentsCount)</h2>
                    <span class="ms-2 badge rounded-pill text-bg-secondary">@commentsCount</span>
                </div>

                @if (commentsCount == 0)
                {
                    <div class="alert alert-light border small mb-4" role="status">
                        No comments yet. Be the first to contribute.
                    </div>
                }
                else
                {
                    <div class="list-group mb-4">
                        @foreach (var c in Model.Comments!.OrderByDescending(c => c.CommentDate))
                        {
                            var commenter = c.UserName ?? "Anonymous";
                            <div class="list-group-item list-group-item-action py-3">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div class="d-flex flex-column">
                                        <strong class="small">@commenter</strong>
                                        <span class="text-muted small">@c.CommentDate.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</span>
                                    </div>
                                    <span class="badge text-bg-light text-muted small">#@commenter.Substring(0, Math.Min(commenter.Length, 10))</span>
                                </div>
                                <p class="mb-0 small">@c.CommentText</p>
                            </div>
                        }
                    </div>
                }

                <!-- Placeholder for future comment form -->
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <h6 class="card-title mb-3">Add a comment</h6>
                        <div class="alert alert-secondary small mb-0">
                            Comment form not implemented yet.
                        </div>
                    </div>
                </div>
            </section>

            <div>
                @await Component.InvokeAsync("Suggestion",Model.NewsType)
            </div>

        </main>

        <aside class="col-12 col-lg-4">
            @* <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="card-title mb-3">At a glance</h6>
                    <ul class="list-unstyled small mb-0">
                        <li class="mb-2"><span class="text-muted">Category:</span> <strong>@Model.NewsType</strong></li>
                        <li class="mb-2"><span class="text-muted">Author:</span> <strong>@authorName</strong></li>
                        <li class="mb-2"><span class="text-muted">Published:</span> <strong>@Model.PublishedDate.ToString("MMM dd, yyyy")</strong></li>
                        <li class="mb-2"><span class="text-muted">Updated:</span> <strong>@Model.LastUpdate.ToString("MMM dd, yyyy HH:mm")</strong></li>
                        <li class="mb-2"><span class="text-muted">Views:</span> <strong>@Model.TotalViews.ToString("N0")</strong></li>
                        <li><span class="text-muted">Comments:</span> <strong>@commentsCount</strong></li>
                    </ul>
                </div>
            </div> *@

            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="card-title mb-3">Share</h6>
                    <div class="d-flex flex-wrap gap-2">
                        <a class="btn btn-sm btn-outline-primary"
                           target="_blank"
                           rel="noopener"
                           href="https://twitter.com/intent/tweet?url=@Uri.EscapeDataString(currentUrl)&text=@Uri.EscapeDataString(Model.NewsTitle ?? "News")">
                            <i class="bi bi-twitter-x me-1"></i> X
                        </a>
                        <a class="btn btn-sm btn-outline-primary"
                           target="_blank"
                           rel="noopener"
                           href="https://www.facebook.com/sharer/sharer.php?u=@Uri.EscapeDataString(currentUrl)">
                            <i class="bi bi-facebook me-1"></i> Facebook
                        </a>
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="navigator.clipboard.writeText('@currentUrl')">
                            <i class="bi bi-clipboard me-1"></i> Copy link
                        </button>
                    </div>


                    <div class="d-flex flex-wrap gap-2">
                        @await Component.InvokeAsync("TopNews")
                    </div>


                </div>
            </div>
        </aside>
    </div>
</div>

